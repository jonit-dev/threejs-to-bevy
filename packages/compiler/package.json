{
  "name": "@threenative/compiler",
  "version": "0.1.10",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm --filter @threenative/sdk build && tsc -p tsconfig.json",
    "lint": "pnpm --filter @threenative/sdk build && tsc -p tsconfig.json --noEmit",
    "test": "node scripts/run-tests.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@threenative/authoring": "workspace:*",
    "@threenative/ir": "workspace:*",
    "@threenative/r3f": "workspace:*",
    "@threenative/script-stdlib": "workspace:*",
    "@threenative/sdk": "workspace:*",
    "@threenative/ui": "workspace:*",
    "three": "0.181.2",
    "three-mesh-bvh": "0.9.10",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@types/three": "0.181.0"
  }
}
