{
  "name": "@threenative/script-stdlib",
  "version": "0.1.11",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm generate && tsc -p tsconfig.json",
    "check:generated": "node scripts/generate-bundle-source.mjs --check",
    "generate": "node scripts/generate-bundle-source.mjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node scripts/run-tests.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.19.25"
  }
}
