{
  "name": "@threenative/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "tn": "./dist/index.js"
  },
  "scripts": {
    "build": "pnpm --filter @threenative/compiler build && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @threenative/compiler build && node scripts/run-tests.mjs",
    "tn": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.19.25"
  },
  "dependencies": {
    "@threenative/compiler": "workspace:*"
  }
}
