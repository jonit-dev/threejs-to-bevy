{
  "name": "@threenative/cli",
  "version": "0.1.5",
  "type": "module",
  "types": "./dist/index.d.ts",
  "bin": {
    "tn": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/copy-templates.mjs && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node scripts/run-tests.mjs",
    "tn": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@types/pngjs": "^6.0.5"
  },
  "dependencies": {
    "@threenative/authoring": "workspace:*",
    "@threenative/compiler": "workspace:*",
    "@threenative/ir": "workspace:*",
    "@threenative/runtime-web-three": "workspace:*",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0"
  }
}
