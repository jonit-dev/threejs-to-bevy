{
  "name": "@threenative/cli",
  "version": "0.1.11",
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cookbook": {
      "types": "./dist/cookbook/parse.d.ts",
      "default": "./dist/cookbook/parse.js"
    },
    "./screenshotMetrics": {
      "types": "./dist/commands/screenshotMetrics.d.ts",
      "default": "./dist/commands/screenshotMetrics.js"
    },
    "./overlay-scaffold": {
      "types": "./dist/overlays/scaffoldRegistry.d.ts",
      "default": "./dist/overlays/scaffoldRegistry.js"
    }
  },
  "bin": {
    "tn": "./dist/index.js"
  },
  "files": [
    "data",
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/copy-templates.mjs && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node scripts/run-tests.mjs",
    "tn": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@types/pngjs": "^6.0.5",
    "@types/sql.js": "^1.4.11"
  },
  "dependencies": {
    "@threenative/authoring": "workspace:*",
    "@threenative/authoring-client": "workspace:*",
    "@threenative/compiler": "workspace:*",
    "@threenative/ir": "workspace:*",
    "@threenative/runtime-web-three": "workspace:*",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "sql.js": "^1.14.1",
    "typescript": "^5.9.3"
  }
}
