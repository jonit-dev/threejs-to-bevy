{
  "name": "@threenative/ir",
  "version": "0.1.10",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./bundlePaths": {
      "types": "./dist/bundlePaths.d.ts",
      "default": "./dist/bundlePaths.js"
    },
    "./conformance": {
      "types": "./dist/conformance.d.ts",
      "default": "./dist/conformance.js"
    },
    "./input": {
      "types": "./dist/input.d.ts",
      "default": "./dist/input.js"
    },
    "./runtimeConfig": {
      "types": "./dist/runtimeConfig.d.ts",
      "default": "./dist/runtimeConfig.js"
    },
    "./reflection": {
      "types": "./dist/reflection.d.ts",
      "default": "./dist/reflection.js"
    },
    "./runtimeDiagnostics": {
      "types": "./dist/runtimeDiagnostics.d.ts",
      "default": "./dist/runtimeDiagnostics.js"
    },
    "./shaderCodegen": {
      "types": "./dist/shaderCodegen.d.ts",
      "default": "./dist/shaderCodegen.js"
    },
    "./capabilities/*": "./capabilities/*",
    "./diagnostics/*": "./diagnostics/*",
    "./schemas/*": "./schemas/*"
  },
  "files": [
    "capabilities",
    "diagnostics",
    "dist",
    "schemas"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node scripts/run-tests.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.19.25"
  }
}
