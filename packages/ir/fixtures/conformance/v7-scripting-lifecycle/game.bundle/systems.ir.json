{
  "schema": "threenative.systems",
  "version": "0.1.0",
  "lifecycle": {
    "replay": "fixed-trace",
    "state": "system-local-disallowed",
    "hotReload": "invalidate",
    "appStates": [
      {
        "id": "Game",
        "initial": "cold",
        "source": {
          "resource": "Lifecycle",
          "field": "phase"
        },
        "values": [
          "cold",
          "booted",
          "fixed",
          "updated"
        ]
      }
    ],
    "computedStates": [
      {
        "id": "ScoreBand",
        "fallback": "low",
        "source": {
          "resource": "Score",
          "field": "band"
        },
        "values": [
          "low",
          "high"
        ]
      }
    ],
    "substates": [
      {
        "id": "Combat",
        "parent": "Game",
        "parentValue": "updated",
        "fallback": "safe",
        "source": {
          "resource": "Lifecycle",
          "field": "combat"
        },
        "values": [
          "safe",
          "engaged"
        ]
      }
    ]
  },
  "observers": [
    {
      "event": "LifecycleEvent",
      "propagation": "target-ancestors",
      "phases": [
        "target",
        "bubble"
      ]
    }
  ],
  "componentHooks": [
    {
      "component": "Health",
      "hooks": [
        "onAdd",
        "onInsert"
      ]
    }
  ],
  "channels": [
    {
      "id": "lifecycle",
      "event": "LifecycleEvent",
      "delivery": "fixed-trace"
    }
  ],
  "tasks": [
    {
      "id": "lifecycleHandoff",
      "schedule": "update",
      "mode": "fixed-trace",
      "channel": "lifecycle"
    }
  ],
  "systems": [
    {
      "name": "bootLifecycle",
      "schedule": "startup",
      "commands": [],
      "eventReads": [],
      "eventWrites": [
        "LifecycleEvent"
      ],
      "queries": [],
      "reads": [],
      "resourceReads": [
        "Lifecycle",
        "Score"
      ],
      "resourceWrites": [
        "Lifecycle"
      ],
      "services": [],
      "script": {
        "bundle": "scripts.bundle.js",
        "exportName": "system_bootLifecycle"
      },
      "writes": []
    },
    {
      "name": "fixedAccumulator",
      "schedule": "fixedUpdate",
      "commands": [],
      "eventReads": [
        "LifecycleEvent"
      ],
      "eventWrites": [
        "LifecycleEvent"
      ],
      "queries": [],
      "reads": [],
      "resourceReads": [
        "Lifecycle",
        "Score"
      ],
      "resourceWrites": [
        "Lifecycle",
        "Score"
      ],
      "services": [
        "animation.play"
      ],
      "script": {
        "bundle": "scripts.bundle.js",
        "exportName": "system_fixedAccumulator"
      },
      "writes": []
    },
    {
      "name": "updateDamage",
      "schedule": "update",
      "commands": [
        {
          "kind": "spawn",
          "entity": "damage.marker",
          "components": [
            "Health"
          ]
        }
      ],
      "eventReads": [
        "DamageEvent",
        "LifecycleEvent"
      ],
      "eventWrites": [
        "LifecycleEvent"
      ],
      "queries": [],
      "reads": [],
      "resourceReads": [
        "Lifecycle",
        "Score"
      ],
      "resourceWrites": [
        "Lifecycle",
        "Score"
      ],
      "services": [],
      "script": {
        "bundle": "scripts.bundle.js",
        "exportName": "system_updateDamage"
      },
      "writes": [
        "Health"
      ]
    },
    {
      "name": "postLifecycle",
      "schedule": "postUpdate",
      "commands": [
        {
          "kind": "despawn",
          "entity": "damage.marker"
        }
      ],
      "eventReads": [
        "LifecycleEvent"
      ],
      "eventWrites": [
        "LifecycleEvent"
      ],
      "queries": [],
      "reads": [],
      "resourceReads": [
        "Lifecycle",
        "Score"
      ],
      "resourceWrites": [
        "Lifecycle"
      ],
      "services": [],
      "script": {
        "bundle": "scripts.bundle.js",
        "exportName": "system_postLifecycle"
      },
      "writes": []
    }
  ]
}
