      "eventReads": [
        "LifecycleEvent"
      ],
      "eventWrites": [
        "LifecycleEvent"
      ],
      "queries": [],
      "reads": [],
      "resourceReads": [
        "Lifecycle",
        "Score"
      ],
      "resourceWrites": [
        "Lifecycle"
      ],
      "services": [],
      "script": {
        "bundle": "scripts.bundle.js",
        "exportName": "system_postLifecycle"
      },
      "writes": []
    }
  ]
}
