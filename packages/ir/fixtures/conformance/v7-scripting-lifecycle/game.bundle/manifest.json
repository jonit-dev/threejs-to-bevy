{
  "schema": "threenative.bundle",
  "version": "0.1.0",
  "name": "conformance-v7-scripting-lifecycle",
  "requiredCapabilities": {
    "ecs": [
      "component-schemas",
      "event-schemas",
      "events",
      "resource-schemas",
      "resources"
    ],
    "scripting": [
      "command.despawn",
      "command.spawn",
      "event-reads",
      "event-writes",
      "hot-reload.invalidate",
      "larger-fixtures",
      "replay.fixed-trace",
      "resource-reads",
      "resource-writes",
      "schedule.fixedUpdate",
      "schedule.postUpdate",
      "schedule.startup",
      "schedule.update",
      "script-bundle",
      "service.animation.play",
      "state.app",
      "state.computed",
      "state.substate",
      "state.system-local-disallowed",
      "systems"
    ]
  },
  "entry": {
