{
  "schema": "threenative.event-schemas",
  "version": "0.1.0",
  "schemas": {
    "DamageEvent": {
      "fields": {
        "amount": {
          "kind": "number",
          "required": true
        },
        "target": {
          "kind": "string",
          "required": true
        }
      }
    },
    "LifecycleEvent": {
      "fields": {
        "combat": {
          "kind": "string",
          "required": false
        },
        "componentHooks": {
          "kind": "string",
          "required": false
        },
        "componentType": {
          "kind": "string",
          "required": false
        },
        "game": {
          "kind": "string",
          "required": false
        },
        "observerRoute": {
          "kind": "string",
          "required": false
        },
        "phase": {
          "kind": "string",
          "required": true
        },
        "score": {
          "kind": "number",
          "required": true
        },
        "scoreBand": {
          "kind": "string",
          "required": false
        }
      }
    }
  }
}
