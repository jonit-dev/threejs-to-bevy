{
  "schema": "threenative.runtime-config",
  "version": "0.1.0",
  "renderer": {
    "antialias": "msaa4",
    "bloom": {
      "enabled": true,
      "intensity": 1,
      "threshold": 0.45
    },
    "colorGrading": {
      "contrast": 0.08,
      "exposure": 1.05,
      "saturation": 1.08,
      "toneMapping": "aces"
    },
    "renderLook": {
      "version": 1,
      "profile": "balanced",
      "overrides": {
        "bloomIntensity": 0.85
      }
    }
  },
  "time": {
    "fixedDelta": 0.016666666666666666,
    "paused": false
  },
  "window": {
    "height": 720,
    "width": 1280
  }
}
