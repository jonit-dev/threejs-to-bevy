{
  "schema": "threenative.runtime-config",
  "version": "0.1.0",
  "renderer": {
    "antialias": "msaa4",
    "colorGrading": {
      "contrast": 0.1,
      "exposure": 1.1,
      "saturation": 0.9,
      "toneMapping": "aces"
    },
    "depthOfField": {
      "aperture": 0.025,
      "enabled": true,
      "focusDistance": 8,
      "maxBlur": 0.012
    },
    "renderPath": "forward"
  },
  "time": {
    "fixedDelta": 0.016666666666666666,
    "paused": false
  },
  "window": {
    "height": 720,
    "width": 1280
  }
}
