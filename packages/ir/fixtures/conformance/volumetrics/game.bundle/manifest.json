{
  "schema": "threenative.bundle",
  "version": "0.1.0",
  "name": "volumetrics",
  "requiredCapabilities": {
    "environment": ["atmosphere", "scene"],
    "rendering": [
      "camera.perspective",
      "material.standard",
      "mesh-renderer",
      "mesh.primitive.box",
      "shadows",
      "volumetric-god-rays",
      "volumetric-height-fog"
    ]
  },
  "entry": { "environmentScene": "environment.scene.json", "world": "world.ir.json" },
  "files": {
    "assets": "assets.manifest.json",
    "materials": "materials.ir.json",
    "runtimeConfig": "runtime.config.json",
    "targetProfile": "target.profile.json"
  }
}
