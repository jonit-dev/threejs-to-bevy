{
  "schema": "threenative.local-data",
  "version": "0.1.0",
  "autosave": {
    "checkpointEvents": ["CheckpointReached"],
    "debounceMs": 250,
    "intervalSeconds": 30
  },
  "components": [
    {
      "id": "Inventory",
      "schema": {
        "fields": {
          "items": { "kind": "string" }
        }
      }
    }
  ],
  "migration": {
    "currentVersion": 2,
    "migrators": [1]
  },
  "resources": [
    {
      "id": "Progress",
      "schema": {
        "fields": {
          "level": { "kind": "integer" }
        }
      }
    }
  ],
  "saveSlots": [
    {
      "appVersion": "1.0.0",
      "id": "slot.main",
      "schemaVersion": 2
    }
  ],
  "settings": [
    {
      "defaultValue": 0.8,
      "group": "audio",
      "key": "audio.master",
      "kind": "number",
      "max": 1,
      "min": 0
    },
    {
      "defaultValue": "normal",
      "enumValues": ["highContrast", "normal"],
      "group": "accessibility",
      "key": "accessibility.contrast",
      "kind": "string"
    }
  ]
}
