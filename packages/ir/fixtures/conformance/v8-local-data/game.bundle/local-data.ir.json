{
  "schema": "threenative.local-data",
  "version": "0.1.0",
  "storage": "local-only",
  "saveSlots": [
    {
      "id": "slot.autosave",
      "label": "Autosave",
      "maxBytes": 65536,
      "version": "1.0.0",
      "resources": ["PlayerProgress"],
      "components": [
        {
          "component": "Checkpoint",
          "entity": "player"
        }
      ]
    }
  ],
  "settings": [
    {
      "id": "controls.invertY",
      "group": "controls",
      "kind": "boolean",
      "default": false
    },
    {
      "id": "audio.masterVolume",
      "group": "audio",
      "kind": "number",
      "default": 0.8,
      "min": 0,
      "max": 1
    },
    {
      "id": "video.displayMode",
      "group": "video",
      "kind": "string",
      "default": "windowed",
      "values": ["windowed", "fullscreen"]
    },
    {
      "id": "accessibility.reducedMotion",
      "group": "accessibility",
      "kind": "boolean",
      "default": false
    }
  ],
  "migrations": [
    {
      "id": "progress-v0-to-v1",
      "appliesTo": "slot.autosave",
      "fromVersion": "0.9.0",
      "toVersion": "1.0.0",
      "strategy": "diagnostic",
      "hint": "Import the old progress value into PlayerProgress.level before loading this slot."
    }
  ],
  "checkpoints": [
    {
      "id": "checkpoint.reached",
      "event": "CheckpointReached",
      "saveSlot": "slot.autosave",
      "schedule": "postUpdate"
    }
  ]
}
