{
  "schema": "threenative.interactions",
  "version": "0.1.0",
  "id": "physics-objectives",
  "interactions": [
    { "id": "checkpoint", "detector": { "kind": "distance2d", "radius": 1, "source": { "entity": "sensor" }, "target": { "entity": "pickup" } }, "gate": { "kind": "once" }, "effects": [{ "kind": "emitEvent", "event": "checkpoint.hit" }] },
    { "id": "hazard", "detector": { "kind": "overlap", "source": { "entity": "player" }, "target": { "entity": "enemy" } }, "gate": { "kind": "cooldown", "ticks": 2 }, "effects": [{ "kind": "addResource", "resource": "Score", "field": "value", "value": -1 }] },
    { "id": "pickup", "detector": { "kind": "distance2d", "radius": 1, "source": { "entity": "sensor" }, "target": { "entity": "pickup" } }, "gate": { "kind": "once-per-target" }, "effects": [{ "kind": "addResource", "resource": "Score", "field": "value", "value": 1 }, { "kind": "despawn", "target": "detected" }], "complete": { "when": { "resource": "Score", "field": "value", "gte": 0 }, "event": "match.win" } },
    { "id": "projectile", "detector": { "kind": "event", "event": "CollisionEvent", "source": { "entity": "player" }, "target": { "entity": "enemy" } }, "gate": { "kind": "once-per-target" }, "effects": [{ "kind": "emitEvent", "event": "projectile.hit" }] },
    { "id": "residual-overlap-boundary", "detector": { "kind": "overlap", "source": { "entity": "residual-overlap-source" }, "target": { "entity": "residual-overlap-boundary" } }, "gate": { "kind": "once" }, "effects": [{ "kind": "addResource", "resource": "Score", "field": "value", "value": 10 }] },
    { "id": "residual-overlap-outside", "detector": { "kind": "overlap", "source": { "entity": "residual-small-source" }, "target": { "entity": "residual-small-outside" } }, "gate": { "kind": "once" }, "effects": [{ "kind": "addResource", "resource": "Score", "field": "value", "value": 100 }] },
    { "id": "residual-typed-state", "detector": { "kind": "distance3d", "radius": 1, "source": { "entity": "residual-typed-source" }, "target": { "entity": "residual-typed-target" } }, "gate": { "kind": "once" }, "when": [{ "target": "source", "component": "Collider", "field": "kind", "equals": "box" }, { "target": "source", "component": "Health", "field": "value", "equals": 3 }], "effects": [{ "kind": "patchComponent", "target": "source", "component": "Collider", "patch": { "friction": 0.25 } }, { "kind": "patchComponent", "target": "source", "component": "Health", "patch": { "value": 2 } }, { "kind": "setTransform", "target": "source", "rotation": [0, 0.70710677, 0, 0.70710677] }] }
  ]
}
