{
  "schema": "threenative.ui",
  "version": "0.1.0",
  "fonts": [
    { "asset": "assets/fonts/ui-regular.ttf", "boldAsset": "assets/fonts/ui-bold.ttf", "family": "ui-proof" }
  ],
  "focusOrder": ["player.name", "audio.volume", "selected.item", "focused.confirm", "mobile.jump"],
  "root": {
    "id": "advanced.ui",
    "kind": "column",
    "accessibilityLabel": "Mission interface",
    "layout": { "direction": "column", "width": 420, "height": 620, "padding": 18 },
    "responsive": [
      { "target": "desktop", "layout": { "width": 420, "height": 620 } },
      { "target": "mobile", "layout": { "width": 340, "height": 700, "padding": 12 } }
    ],
    "style": {
      "backgroundColor": "#111827",
      "fontWeight": "bold",
      "gradient": { "kind": "linear", "from": "#172033", "to": "#0f172a", "angle": 90 },
      "shadow": { "color": "#00000099", "offsetX": 4, "offsetY": 6, "blur": 12, "spread": 1 }
    },
    "children": [
      {
        "id": "player.name",
        "kind": "textInput",
        "label": "Player name",
        "accessibilityLabel": "Player name",
        "action": "SetPlayerName",
        "focusable": true,
        "text": "Nova",
        "layout": { "width": 260, "height": 44 },
        "style": { "backgroundColor": "#263449", "borderColor": "#7dd3fc", "borderWidth": 2, "color": "#ffffff" }
      },
      {
        "id": "quest.frame",
        "kind": "image",
        "src": "assets/ui-frame.png",
        "accessibilityLabel": "Quest frame",
        "layout": { "width": 160, "height": 64 },
        "image": {
          "atlas": { "x": 0, "y": 0, "width": 4, "height": 4 },
          "nineSlice": { "top": 1, "right": 1, "bottom": 1, "left": 1 },
          "scaleMode": "stretch",
          "sourceSize": { "width": 4, "height": 4 }
        }
      },
      {
        "id": "audio.volume",
        "kind": "slider",
        "label": "Volume",
        "accessibilityLabel": "Volume",
        "action": "SetVolume",
        "focusable": true,
        "min": 0,
        "max": 1,
        "step": 0.05,
        "value": 0.5,
        "valueText": "50 percent",
        "navigation": { "left": "player.name", "right": "selected.item" },
        "layout": { "width": 260, "height": 36 }
      },
      {
        "id": "selected.item",
        "kind": "button",
        "label": "Crystal Key",
      "action": "InspectItem",
      "focusable": true,
      "binding": {
        "kind": "resource",
        "name": "Selection",
        "field": "itemSelected"
      },
        "navigation": { "left": "audio.volume", "right": "focused.confirm" },
      "effects": [
        {
          "id": "selected.item.hover",
          "kind": "glow",
          "trigger": "hover",
          "color": "#fbbf24",
          "radius": 8,
          "intensity": 0.6,
          "fallback": "outline"
        },
        {
            "id": "selected.item.glow",
            "kind": "glow",
            "trigger": "selected",
            "color": "#66ccff",
            "radius": 12,
            "intensity": 0.75,
            "fallback": "shadow"
          }
        ]
      },
      {
        "id": "quest.target",
        "kind": "button",
        "label": "Ancient Door",
        "action": "TrackQuest",
        "effects": [
          {
            "id": "quest.target.pulse",
            "kind": "pulse",
            "trigger": "predicate",
            "predicate": {
              "resource": "QuestState",
              "field": "targetActive",
              "equals": true
            },
            "pulse": {
              "durationMs": 900,
              "iterations": 3
            },
            "fallback": "outline"
          }
        ]
      },
      {
        "id": "invalid.input",
        "kind": "text",
        "text": "Name required",
        "effects": [
          {
            "id": "invalid.input.outline",
            "kind": "outline",
            "trigger": "predicate",
            "predicate": {
              "resource": "FormState",
              "field": "invalid",
              "equals": true
            },
            "color": "#ff3366",
            "radius": 2
          }
        ]
      },
      {
        "id": "critical.health",
        "kind": "bar",
        "accessibilityLabel": "Critical health",
        "value": 2,
        "max": 10,
        "layout": { "width": 160, "height": 12 },
        "effects": [
          {
            "id": "critical.health.tint",
            "kind": "tint",
            "trigger": "predicate",
            "predicate": {
              "resource": "PlayerVitals",
              "field": "critical",
              "equals": true
            },
            "color": "#ff0033",
            "intensity": 0.65
          }
        ]
      },
      {
        "id": "focused.confirm",
        "kind": "button",
        "label": "Confirm",
        "action": "Confirm",
        "focusable": true,
        "effects": [
          {
            "id": "focused.confirm.ring",
            "kind": "focusRing",
            "trigger": "focus",
            "color": "#ffffff",
            "radius": 4,
            "fallback": "outline"
          }
        ]
      },
      {
        "id": "parity.row",
        "kind": "row",
        "layout": { "direction": "row", "width": 260, "height": 48 },
        "children": [
          {
            "id": "parity.stack",
            "kind": "stack",
            "layout": { "width": 120, "height": 44 },
            "children": [
              {
                "id": "mobile.jump",
                "kind": "touchControl",
                "label": "Jump",
                "accessibilityLabel": "Jump",
                "action": "Jump",
                "focusable": true,
                "layout": { "width": 96, "height": 40 }
              }
            ]
          }
        ]
      },
      {
        "id": "enemy.nameplate",
        "kind": "text",
        "text": "Scout",
        "attachTo": {
          "target": {
            "kind": "entity",
            "id": "enemy.1"
          },
          "localOffset": [0, 2, 0],
          "anchor": "top",
          "clamp": "screenEdge",
          "distanceScale": {
            "min": 0.6,
            "max": 1.2
          },
          "occlusion": "hide",
          "maxDistance": 80,
          "sortPriority": 10
        }
      },
      {
        "id": "pickup.label",
        "kind": "text",
        "text": "Energy Cell",
        "attachTo": {
          "target": {
            "kind": "selectedEntity",
            "binding": "selection.current"
          },
          "localOffset": [0, 1, 0],
          "anchor": "bottom",
          "clamp": "screenEdge",
          "occlusion": "show",
          "sortPriority": 5
        }
      },
      {
        "id": "bold.face.proof",
        "kind": "text",
        "text": "",
        "layout": { "position": "absolute", "inset": { "left": 0, "top": 0 }, "width": 1, "height": 1 },
        "style": { "fontFamily": "ui-proof", "fontWeight": "bold", "opacity": 0 }
      }
    ]
  }
}
