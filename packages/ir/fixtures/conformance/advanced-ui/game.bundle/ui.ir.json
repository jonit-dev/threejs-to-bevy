{
  "schema": "threenative.ui",
  "version": "0.1.0",
  "root": {
    "id": "advanced.ui",
    "kind": "column",
    "accessibilityLabel": "Mission interface",
    "layout": { "direction": "column", "width": 420, "height": 620, "padding": 18 },
    "style": {
      "backgroundColor": "#111827",
      "gradient": { "kind": "linear", "from": "#172033", "to": "#0f172a", "angle": 90 },
      "shadow": { "color": "#00000099", "offsetX": 4, "offsetY": 6, "blur": 12, "spread": 1 }
    },
    "children": [
      {
        "id": "player.name",
        "kind": "textInput",
        "label": "Player name",
        "accessibilityLabel": "Player name",
        "action": "SetPlayerName",
        "focusable": true,
        "text": "Nova",
        "layout": { "width": 260, "height": 44 },
        "style": { "backgroundColor": "#263449", "borderColor": "#7dd3fc", "borderWidth": 2, "color": "#ffffff" }
      },
      {
        "id": "quest.frame",
        "kind": "image",
        "src": "assets/ui-frame.png",
        "accessibilityLabel": "Quest frame",
        "layout": { "width": 160, "height": 64 },
        "image": {
          "atlas": { "x": 0, "y": 0, "width": 4, "height": 4 },
          "nineSlice": { "top": 1, "right": 1, "bottom": 1, "left": 1 },
          "scaleMode": "stretch",
          "sourceSize": { "width": 4, "height": 4 }
        }
      },
      {
        "id": "selected.item",
        "kind": "button",
        "label": "Crystal Key",
        "action": "InspectItem",
        "effects": [
          {
            "id": "selected.item.glow",
            "kind": "glow",
            "trigger": "selected",
            "color": "#66ccff",
            "radius": 12,
            "intensity": 0.75,
            "fallback": "shadow"
          }
        ]
      },
      {
        "id": "quest.target",
        "kind": "button",
        "label": "Ancient Door",
        "action": "TrackQuest",
        "effects": [
          {
            "id": "quest.target.pulse",
            "kind": "pulse",
            "trigger": "predicate",
            "predicate": {
              "resource": "QuestState",
              "field": "targetActive",
              "equals": true
            },
            "pulse": {
              "durationMs": 900,
              "iterations": 3
            },
            "fallback": "outline"
          }
        ]
      },
      {
        "id": "invalid.input",
        "kind": "text",
        "text": "Name required",
        "effects": [
          {
            "id": "invalid.input.outline",
            "kind": "outline",
            "trigger": "predicate",
            "predicate": {
              "resource": "FormState",
              "field": "invalid",
              "equals": true
            },
            "color": "#ff3366",
            "radius": 2
          }
        ]
      },
      {
        "id": "critical.health",
        "kind": "bar",
        "accessibilityLabel": "Critical health",
        "value": 2,
        "max": 10,
        "effects": [
          {
            "id": "critical.health.tint",
            "kind": "tint",
            "trigger": "predicate",
            "predicate": {
              "resource": "PlayerVitals",
              "field": "critical",
              "equals": true
            },
            "color": "#ff0033",
            "intensity": 0.65
          }
        ]
      },
      {
        "id": "focused.confirm",
        "kind": "button",
        "label": "Confirm",
        "action": "Confirm",
        "focusable": true,
        "effects": [
          {
            "id": "focused.confirm.ring",
            "kind": "focusRing",
            "trigger": "focus",
            "color": "#ffffff",
            "radius": 4,
            "fallback": "outline"
          }
        ]
      },
      {
        "id": "enemy.nameplate",
        "kind": "text",
        "text": "Scout",
        "attachTo": {
          "target": {
            "kind": "entity",
            "id": "enemy.1"
          },
          "localOffset": [0, 2, 0],
          "anchor": "top",
          "clamp": "screenEdge",
          "distanceScale": {
            "min": 0.6,
            "max": 1.2
          },
          "occlusion": "hide",
          "maxDistance": 80,
          "sortPriority": 10
        }
      },
      {
        "id": "pickup.label",
        "kind": "text",
        "text": "Energy Cell",
        "attachTo": {
          "target": {
            "kind": "selectedEntity",
            "binding": "selection.current"
          },
          "localOffset": [0, 1, 0],
          "anchor": "bottom",
          "clamp": "screenEdge",
          "occlusion": "show",
          "sortPriority": 5
        }
      }
    ]
  }
}
