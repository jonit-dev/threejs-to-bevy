{
  "schema": "threenative.ui",
  "version": "0.1.0",
  "focusOrder": ["volume", "slot", "equip"],
  "root": {
    "id": "settings",
    "kind": "column",
    "accessibilityLabel": "Settings",
    "children": [
      {
        "id": "volume",
        "kind": "slider",
        "accessibilityLabel": "Volume",
        "action": "SetVolume",
        "focusable": true,
        "binding": { "kind": "resource", "name": "Settings", "field": "volume" },
        "min": 0,
        "max": 1,
        "step": 0.05,
        "valueText": "50 percent"
      },
      {
        "id": "frame",
        "kind": "image",
        "src": "assets/ui/frame.png",
        "accessibilityLabel": "Inventory frame",
        "image": {
          "nineSlice": { "top": 4, "right": 4, "bottom": 4, "left": 4 },
          "scaleMode": "stretch",
          "sourceSize": { "width": 64, "height": 32 }
        }
      },
      {
        "id": "slot",
        "kind": "button",
        "accessibilityLabel": "Open item actions",
        "label": "Item",
        "focusable": true,
        "action": "OpenItemActions"
      },
      {
        "id": "item-menu",
        "kind": "contextMenu",
        "anchorId": "slot",
        "accessibilityLabel": "Item actions",
        "children": [
          {
            "id": "equip",
            "kind": "button",
            "label": "Equip",
            "focusable": true,
            "action": "Equip"
          }
        ]
      }
    ]
  }
}
