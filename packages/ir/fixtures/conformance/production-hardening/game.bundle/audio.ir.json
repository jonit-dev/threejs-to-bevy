{
  "schema": "threenative.audio",
  "version": "0.1.0",
  "buses": [
    { "id": "bus.master", "gain": 1 },
    { "id": "bus.music", "parent": "bus.master", "gain": 0.8 },
    { "id": "bus.sfx", "parent": "bus.master", "gain": 0.9 }
  ],
  "duckingRules": [
    {
      "id": "duck.music",
      "sourceBus": "bus.sfx",
      "targetBus": "bus.music",
      "gain": 0.35,
      "attack": 0.05,
      "release": 0.2
    }
  ],
  "listeners": [
    { "id": "listener.main", "position": [0, 0, 0], "binding": { "kind": "activeCamera" } }
  ],
  "emitters": [
    {
      "id": "emitter.ui",
      "position": [0, 0, 3],
      "attenuation": { "curve": "linear", "minDistance": 1, "maxDistance": 8, "rolloffFactor": 1 }
    }
  ],
  "controls": [
    { "id": "music.pause", "kind": "pause", "target": "music.menu" },
    { "id": "music.queryPaused", "kind": "query", "target": "music.menu" },
    { "id": "music.seek", "kind": "seek", "target": "music.menu", "at": 6.5 },
    { "id": "music.resume", "kind": "resume", "target": "music.menu" },
    { "id": "music.stop", "kind": "stop", "target": "music.menu" },
    { "id": "music.queryStopped", "kind": "query", "target": "music.menu" }
  ],
  "music": [
    { "id": "music.menu", "asset": "music.menu", "loop": true, "autoplay": true, "bus": "bus.music", "volume": 0.5 }
  ],
  "oneShots": [
    { "id": "sound.confirm", "asset": "sound.confirm", "event": "UiConfirm", "bus": "bus.sfx", "emitter": "emitter.ui", "volume": 0.75 }
  ],
  "musicTransitions": [
    { "id": "transition.menu", "kind": "crossfade", "playbackId": "music.menu", "state": "menu", "to": "music.menu", "duration": 0.2 }
  ],
  "tones": [
    { "id": "tone.confirm", "bus": "bus.sfx", "duration": 0.2, "frequency": 880, "pitch": 1, "volume": 0.5, "waveform": "sine" }
  ]
}
