{
  "schema": "threenative.scripting-context-trace",
  "version": "0.1.0",
  "entity": {
    "id": "player",
    "components": {
      "Transform": {
        "position": [0, 1, 0],
        "rotation": [0, 0, 0, 1],
        "scale": [1, 1, 1]
      },
      "PlayerState": {
        "hp": 3,
        "status": "ready"
      }
    }
  },
  "operations": [
