    "componentReads": [
      { "hp": 3, "status": "ready" },
      { "hp": 2, "status": "ready" },
      { "hp": 2, "status": "moving" }
    ],
    "effectOrder": ["Transform", "PlayerState", "PlayerState"],
    "inputTicks": [
      { "action": true, "pressed": true, "released": false },
      { "action": true, "pressed": false, "released": false },
      { "action": false, "pressed": false, "released": true }
    ]
  }
