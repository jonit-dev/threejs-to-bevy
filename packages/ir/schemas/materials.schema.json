{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.threenative.local/v1/materials.schema.json",
  "type": "object",
  "required": ["schema", "version", "materials"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "threenative.materials" },
    "version": { "const": "0.1.0" },
    "materials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "color"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["standard", "extended"] },
          "alphaMode": { "enum": ["opaque", "mask", "blend"] },
          "blendMode": { "enum": ["normal", "additive", "multiply", "premultipliedAlpha"] },
          "depthTest": { "type": "boolean" },
          "depthWrite": { "type": "boolean" },
          "extension": {
            "type": "object",
            "required": ["preset"],
            "additionalProperties": false,
            "properties": {
              "preset": { "enum": ["unlitMasked", "foliage"] },
              "doubleSided": { "type": "boolean" }
            }
          },
          "renderOrder": { "type": "integer" },
          "alphaCutoff": { "type": "number", "minimum": 0, "maximum": 1 },
          "color": {
            "oneOf": [
              { "type": "string", "pattern": "^#(?:[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$" },
              { "type": "array", "minItems": 3, "maxItems": 4, "items": { "type": "number" } }
            ]
          },
          "emissive": {
            "oneOf": [
              { "type": "string", "pattern": "^#(?:[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$" },
              { "type": "array", "minItems": 3, "maxItems": 4, "items": { "type": "number" } }
            ]
          },
          "emissiveIntensity": { "type": "number", "minimum": 0 },
          "clearcoat": { "type": "number", "minimum": 0, "maximum": 1 },
          "clearcoatRoughness": { "type": "number", "minimum": 0, "maximum": 1 },
          "metalness": { "type": "number" },
          "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
          "roughness": { "type": "number" },
          "specularIntensity": { "type": "number", "minimum": 0, "maximum": 1 },
          "transmission": { "type": "number", "minimum": 0, "maximum": 1 },
          "baseColorTexture": { "type": "string", "minLength": 1 },
          "clearcoatTexture": { "type": "string", "minLength": 1 },
          "clearcoatRoughnessTexture": { "type": "string", "minLength": 1 },
          "normalTexture": { "type": "string", "minLength": 1 },
          "metallicRoughnessTexture": { "type": "string", "minLength": 1 },
          "emissiveTexture": { "type": "string", "minLength": 1 },
          "occlusionTexture": { "type": "string", "minLength": 1 },
          "transmissionTexture": { "type": "string", "minLength": 1 },
          "specularTexture": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
