{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.threenative.local/v1/runtime-config.schema.json",
  "type": "object",
  "required": ["schema", "version", "time", "window"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "threenative.runtime-config" },
    "version": { "const": "0.1.0" },
    "renderer": {
      "type": "object",
      "required": ["antialias"],
      "additionalProperties": false,
      "properties": {
        "antialias": { "enum": ["none", "msaa2", "msaa4", "msaa8", "fxaa", "taa", "smaa"] },
        "bloom": {
          "type": "object",
          "required": ["enabled", "intensity", "threshold"],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "intensity": { "type": "number", "minimum": 0 },
            "threshold": { "type": "number", "minimum": 0 }
          }
        },
        "colorGrading": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "contrast": { "type": "number" },
            "exposure": { "type": "number", "exclusiveMinimum": 0 },
            "lut": { "type": "string", "minLength": 1 },
            "saturation": { "type": "number", "minimum": 0 },
            "temperature": { "type": "number" },
            "tint": { "type": "number" },
            "toneMapping": { "enum": ["aces", "linear", "none", "reinhard"] }
          }
        },
        "depthOfField": {
          "type": "object",
          "required": ["enabled", "focusDistance", "aperture", "maxBlur"],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "focusDistance": { "type": "number", "exclusiveMinimum": 0 },
            "aperture": { "type": "number", "minimum": 0 },
            "maxBlur": { "type": "number", "minimum": 0 }
          }
        },
        "renderPath": { "const": "forward" }
      }
    },
    "time": {
      "type": "object",
      "required": ["fixedDelta", "paused"],
      "additionalProperties": false,
      "properties": {
        "fixedDelta": { "type": "number", "exclusiveMinimum": 0 },
        "paused": { "type": "boolean" }
      }
    },
    "window": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": false,
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "title": { "type": "string", "minLength": 1 }
      }
    }
  }
}
