{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.threenative.local/v1/assets.schema.json",
  "type": "object",
  "required": ["schema", "version", "assets"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "threenative.assets" },
    "version": { "const": "0.1.0" },
    "assets": {
      "type": "array",
      "items": { "$ref": "#/$defs/asset" }
    }
  },
  "$defs": {
    "asset": {
      "oneOf": [
        {
          "type": "object",
          "required": ["id", "kind", "format", "primitive"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "kind": { "const": "mesh" },
            "format": { "const": "generated" },
              "primitive": { "enum": ["box", "capsule", "cylinder", "sphere", "plane"] },
            "size": { "type": "array", "items": { "type": "number" } }
          }
        },
        {
          "type": "object",
          "required": ["id", "kind", "format", "path"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "kind": { "const": "model" },
            "format": { "enum": ["glb", "gltf"] },
            "path": { "type": "string", "minLength": 1 },
            "bounds": {
              "type": "object",
              "required": ["min", "max"],
              "additionalProperties": false,
              "properties": {
                "min": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
                "max": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 }
              }
            },
            "animations": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id"],
                "additionalProperties": false,
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "loop": { "type": "boolean" },
                  "sourceClip": { "type": "string", "minLength": 1 },
                  "speed": { "type": "number", "exclusiveMinimum": 0 }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["id", "kind", "format", "path"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "kind": { "const": "audio" },
            "format": { "enum": ["mp3", "ogg", "wav"] },
            "path": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "required": ["id", "kind", "format", "path"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "kind": { "const": "texture" },
            "format": { "enum": ["jpeg", "png"] },
            "path": { "type": "string", "minLength": 1 }
          }
        }
      ]
    }
  }
}
