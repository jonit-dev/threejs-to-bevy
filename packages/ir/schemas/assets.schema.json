{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.threenative.local/v1/assets.schema.json",
  "type": "object",
  "required": ["schema", "version", "assets"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "threenative.assets" },
    "version": { "const": "0.1.0" },
    "assets": {
      "type": "array",
      "items": { "$ref": "#/$defs/asset" }
    }
  },
  "$defs": {
    "asset": {
      "oneOf": [
        {
          "type": "object",
          "required": ["id", "kind", "format", "primitive"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "kind": { "const": "mesh" },
            "format": { "const": "generated" },
              "primitive": {
                "enum": [
                  "annulus",
                  "box",
                  "capsule",
                  "circle",
                  "cone",
                  "conicalFrustum",
                  "custom",
                  "cylinder",
                  "extrudedRectangle",
                  "plane",
                  "regularPolygon",
                  "sphere",
                  "torus"
                ]
              },
            "attributes": {
              "type": "array",
              "items": { "$ref": "#/$defs/meshAttribute" }
            },
            "binaryAttributes": {
              "type": "array",
              "items": { "$ref": "#/$defs/meshBinaryAttribute" }
            },
            "binaryIndices": { "$ref": "#/$defs/meshBinaryIndices" },
            "bounds": { "$ref": "#/$defs/bounds" },
            "budget": {
              "type": "object",
              "required": ["classification", "vertexCount", "limit"],
              "additionalProperties": false,
              "properties": {
                "classification": { "enum": ["standard-prop", "hero-prop", "doodad"] },
                "vertexCount": { "type": "integer", "minimum": 1 },
                "limit": { "type": "integer", "minimum": 1 }
              }
            },
            "generation": {
              "type": "object",
              "required": ["id", "source"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "source": { "enum": ["MeshBuilder", "BufferGeometrySnapshot"] },
                "helper": { "type": "string", "minLength": 1 },
                "seed": { "type": "number" }
              }
            },
            "indices": {
              "type": "array",
              "items": { "type": "integer", "minimum": 0 }
            },
            "size": { "type": "array", "items": { "type": "number" } },
            "topology": { "const": "triangle-list" },
            "usage": { "const": "static" }
          }
        },
        {
          "type": "object",
          "required": ["id", "kind", "format", "path"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "kind": { "const": "model" },
            "format": { "enum": ["glb", "gltf"] },
            "path": { "type": "string", "minLength": 1 },
            "bounds": { "$ref": "#/$defs/bounds" },
            "animations": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id"],
                "additionalProperties": false,
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "loop": { "type": "boolean" },
                  "mask": { "type": "string", "minLength": 1 },
                  "sourceClip": { "type": "string", "minLength": 1 },
                  "speed": { "type": "number", "exclusiveMinimum": 0 }
                }
              }
            },
            "animationGraph": {
              "type": "object",
              "required": ["initialState", "states"],
              "additionalProperties": false,
              "properties": {
                "initialState": { "type": "string", "minLength": 1 },
                "parameters": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "kind"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string", "minLength": 1 },
                      "kind": { "enum": ["boolean", "number", "trigger"] },
                      "default": { "type": ["boolean", "number"] }
                    }
                  }
                },
                "states": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["id", "clip"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string", "minLength": 1 },
                      "clip": { "type": "string", "minLength": 1 },
                      "events": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "required": ["event", "atSeconds"],
                          "additionalProperties": false,
                          "properties": {
                            "event": { "type": "string", "minLength": 1 },
                            "atSeconds": { "type": "number", "minimum": 0 }
                          }
                        }
                      }
                    }
                  }
                },
                "transitions": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["from", "to", "when"],
                    "additionalProperties": false,
                    "properties": {
                      "from": { "type": "string", "minLength": 1 },
                      "to": { "type": "string", "minLength": 1 },
                      "blendSeconds": { "type": "number", "minimum": 0 },
                      "when": {
                        "type": "object",
                        "required": ["parameter"],
                        "additionalProperties": false,
                        "properties": {
                          "parameter": { "type": "string", "minLength": 1 },
                          "equals": { "type": ["boolean", "number"] },
                          "greaterThan": { "type": "number" },
                          "lessThan": { "type": "number" }
                        }
                      }
                    }
                  }
                }
              }
            },
            "masks": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "joints"],
                "additionalProperties": false,
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "joints": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 }
                }
              }
            },
            "morphClips": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "target", "keyframes"],
                "additionalProperties": false,
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "target": { "type": "string", "minLength": 1 },
                  "keyframes": {
                    "type": "array",
                    "minItems": 2,
                    "items": {
                      "type": "object",
                      "required": ["timeSeconds", "weight"],
                      "additionalProperties": false,
                      "properties": {
                        "timeSeconds": { "type": "number", "minimum": 0 },
                        "weight": { "type": "number", "minimum": 0, "maximum": 1 }
                      }
                    }
                  }
                }
              }
            },
            "morphTargets": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id"],
                "additionalProperties": false,
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "defaultWeight": { "type": "number", "minimum": 0, "maximum": 1 }
                }
              }
            },
            "particleEmitters": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "lifetimeSeconds", "maxParticles", "ratePerSecond", "shape"],
                "additionalProperties": false,
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "lifetimeSeconds": { "type": "number", "exclusiveMinimum": 0 },
                  "maxParticles": { "type": "integer", "minimum": 1 },
                  "radius": { "type": "number", "exclusiveMinimum": 0 },
                  "ratePerSecond": { "type": "number", "minimum": 0 },
                  "shape": { "enum": ["point", "sphere"] }
                }
              }
            },
            "skeleton": {
              "type": "object",
              "required": ["joints"],
              "additionalProperties": false,
              "properties": {
                "joints": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["id", "kind", "format", "path"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "kind": { "const": "audio" },
            "format": { "enum": ["mp3", "ogg", "wav"] },
            "path": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "required": ["id", "kind", "format", "path"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "kind": { "const": "texture" },
            "format": { "enum": ["jpeg", "png", "webp"] },
            "path": { "type": "string", "minLength": 1 },
            "wrapS": { "$ref": "#/$defs/textureWrapMode" },
            "wrapT": { "$ref": "#/$defs/textureWrapMode" },
            "minFilter": { "$ref": "#/$defs/textureMinFilter" },
            "magFilter": { "$ref": "#/$defs/textureMagFilter" },
            "repeat": { "$ref": "#/$defs/vec2" },
            "offset": { "$ref": "#/$defs/vec2" },
            "rotation": { "type": "number" },
            "center": { "$ref": "#/$defs/vec2" }
          }
        }
      ]
    },
    "textureWrapMode": { "enum": ["clampToEdge", "mirroredRepeat", "repeat"] },
    "textureMinFilter": {
      "enum": [
        "linear",
        "linearMipmapLinear",
        "linearMipmapNearest",
        "nearest",
        "nearestMipmapLinear",
        "nearestMipmapNearest"
      ]
    },
    "textureMagFilter": { "enum": ["linear", "nearest"] },
    "vec2": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 2,
      "maxItems": 2
    },
    "meshAttribute": {
      "type": "object",
      "required": ["name", "itemSize", "values"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^(position|normal|uv|uv1|color|custom:[A-Za-z_][A-Za-z0-9_]*)$"
        },
        "itemSize": { "enum": [1, 2, 3, 4] },
        "values": { "type": "array", "items": { "type": "number" } }
      }
    },
    "meshBinaryAttribute": {
      "type": "object",
      "required": ["name", "itemSize", "format", "count", "path"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^(position|normal|uv|uv1|color|custom:[A-Za-z_][A-Za-z0-9_]*)$"
        },
        "itemSize": { "enum": [1, 2, 3, 4] },
        "format": { "enum": ["float32x1", "float32x2", "float32x3", "float32x4"] },
        "count": { "type": "integer", "minimum": 1 },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "meshBinaryIndices": {
      "type": "object",
      "required": ["format", "count", "path"],
      "additionalProperties": false,
      "properties": {
        "format": { "enum": ["uint16", "uint32"] },
        "count": { "type": "integer", "minimum": 3 },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "bounds": {
      "type": "object",
      "required": ["min", "max"],
      "additionalProperties": false,
      "properties": {
        "min": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
        "max": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 }
      }
    }
  }
}
