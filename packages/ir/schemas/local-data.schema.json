{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.threenative.local/v1/local-data.schema.json",
  "type": "object",
  "required": ["schema", "version", "storage", "saveSlots", "settings"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "threenative.local-data" },
    "version": { "const": "0.1.0" },
    "storage": { "const": "local-only" },
    "saveSlots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "version"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string" },
          "maxBytes": { "type": "integer", "minimum": 1 },
          "version": { "type": "string", "minLength": 1 },
          "resources": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "components": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["component"],
              "additionalProperties": false,
              "properties": {
                "component": { "type": "string", "minLength": 1 },
                "entity": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "settings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "group", "kind", "default"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "group": { "enum": ["accessibility", "audio", "controls", "video"] },
          "kind": { "enum": ["boolean", "integer", "number", "string"] },
          "default": { "type": ["boolean", "number", "string"] },
          "min": { "type": "number" },
          "max": { "type": "number" },
          "values": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "migrations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "appliesTo", "fromVersion", "toVersion", "strategy", "hint"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "appliesTo": { "type": "string", "minLength": 1 },
          "fromVersion": { "type": "string", "minLength": 1 },
          "toVersion": { "type": "string", "minLength": 1 },
          "strategy": { "const": "diagnostic" },
          "hint": { "type": "string", "minLength": 1 }
        }
      }
    },
    "checkpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "event", "saveSlot", "schedule"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "event": { "type": "string", "minLength": 1 },
          "saveSlot": { "type": "string", "minLength": 1 },
          "schedule": { "enum": ["startup", "fixedUpdate", "update", "postUpdate"] }
        }
      }
    }
  }
}
