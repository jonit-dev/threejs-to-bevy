{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.threenative.local/v1/target-profile.schema.json",
  "type": "object",
  "required": ["schema", "version", "targets"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "threenative.target-profile" },
    "version": { "const": "0.1.0" },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["web", "desktop"] }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxAssetBytes": { "type": "integer", "minimum": 0 },
        "maxBundleBytes": { "type": "integer", "minimum": 0 },
        "maxTerrainCells": { "type": "integer", "minimum": 0 },
        "maxTerrainSplatLayers": { "type": "integer", "minimum": 0 },
        "supportedModelFormats": {
          "type": "array",
          "items": { "enum": ["glb", "gltf"] }
        },
        "supportedTextureFormats": {
          "type": "array",
          "items": { "enum": ["basis", "bc", "dds", "etc2", "astc", "jpeg", "ktx2", "png", "webp"] }
        }
      }
    },
    "performance": {
      "type": "object",
      "required": ["averageFrameMs", "drawCalls", "updatedAt"],
      "additionalProperties": false,
      "properties": {
        "averageFrameMs": { "$ref": "#/$defs/performanceThreshold" },
        "drawCalls": { "$ref": "#/$defs/performanceThreshold" },
        "updatedAt": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "performanceThreshold": {
      "type": "object",
      "required": ["max"],
      "additionalProperties": false,
      "properties": {
        "max": { "type": "number", "minimum": 0 },
        "warn": { "type": "number", "minimum": 0 }
      }
    }
  }
}
