{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.threenative.local/v1/world.schema.json",
  "type": "object",
  "required": ["schema", "version", "entities"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "threenative.world" },
    "version": { "const": "0.1.0" },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "components"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "components": { "type": "object" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "resources": { "type": "object" },
    "events": { "type": "object" },
    "prefabs": { "type": "array" }
  }
}
