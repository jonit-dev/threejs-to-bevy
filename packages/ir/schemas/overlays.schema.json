{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.threenative.local/v1/overlays.schema.json",
  "type": "object",
  "required": ["schema", "version", "overlays"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "threenative.overlays" },
    "version": { "const": "0.1.0" },
    "overlays": {
      "type": "array",
      "items": { "$ref": "#/$defs/overlay" }
    }
  },
  "$defs": {
    "overlay": {
      "type": "object",
      "required": ["id", "entry", "transparent", "zIndex", "input", "messages", "targetProfiles"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "entry": {
          "type": "string",
          "minLength": 1,
          "not": {
            "anyOf": [
              { "pattern": "^/" },
              { "pattern": "\\.\\." },
              { "pattern": "^[A-Za-z][A-Za-z0-9+.-]*:" },
              { "pattern": "<script" },
              { "pattern": "\\\\" }
            ]
          }
        },
        "transparent": { "type": "boolean" },
        "zIndex": { "type": "integer", "minimum": 0 },
        "input": { "enum": ["none", "pointer", "keyboard", "pointer-and-keyboard", "modal"] },
        "targetProfiles": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["web", "desktop"] }
        },
        "messages": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "overlayToGame": {
              "type": "array",
              "items": { "$ref": "#/$defs/message" }
            },
            "gameToOverlay": {
              "type": "array",
              "items": { "$ref": "#/$defs/message" }
            }
          }
        }
      }
    },
    "message": {
      "type": "object",
      "required": ["name", "schema"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?::[a-z][a-z0-9-]*)+$"
        },
        "schema": { "$ref": "#/$defs/messageSchema" }
      }
    },
    "messageSchema": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "object" },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "enum": ["boolean", "integer", "number", "object", "string"]
          }
        },
        "required": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
