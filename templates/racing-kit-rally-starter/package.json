{
  "name": "threenative-racing-kit-rally-starter",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tn build",
    "dev:web": "tn dev --target web",
    "playtest": "tn playtest --scenario playtests/rally-throttle.playtest.json --stable-artifacts --json",
    "game:plan": "tn game plan --goal \"racing kit rally checkpoint game\" --project . --json > artifacts/game-production/plan.json",
    "game:improve": "tn game improve --apply-plan artifacts/game-production/plan.json --project . --json",
    "game:score": "tn game score --project . --json",
    "game:qa": "tn game qa --project . --run-proof --json",
    "game:release": "tn game release --project . --json",
    "validate": "tn validate",
    "validate:authoring": "tn authoring validate --json",
    "verify": "tn verify --frames 4 --json"
  },
  "dependencies": {
    "@threenative/script-stdlib": "workspace:*",
    "@threenative/sdk": "workspace:*"
  },
  "devDependencies": {
    "@threenative/cli": "workspace:*",
    "@types/node": "^20.19.25",
    "typescript": "^5.9.3"
  }
}
