{
  "schemaVersion": 1,
  "name": "hud-resource",
  "target": "web",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "subject": "player.car",
  "warmupFrames": 5,
  "steps": [
    {
      "label": "throttle",
      "press": "KeyW",
      "holdFrames": 20,
      "release": true
    }
  ],
  "assert": {
    "resources": [
      {
        "id": "RallyState",
        "path": "speed",
        "gte": 0.1
      }
    ],
    "hud": [
      {
        "id": "hud",
        "textIncludes": "km/h",
        "changed": true
      }
    ],
    "diagnostics": {
      "runtimeReady": true,
      "noConsoleErrors": true,
      "noNetworkErrors": true,
      "noRuntimeDiagnostics": true
    }
  },
  "artifacts": {
    "screenshots": "before-after",
    "console": true,
    "network": true,
    "runtimeTrace": true
  }
}
