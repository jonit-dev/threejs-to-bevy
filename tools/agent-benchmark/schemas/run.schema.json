{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema": "threenative.agent-benchmark-run",
  "version": 2,
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "version", "runId", "promptId", "condition", "candidate", "session", "ok", "diagnostics", "artifacts", "generatedAt"],
  "properties": {
    "schema": { "const": "threenative.agent-benchmark-run" },
    "version": { "const": 2 },
    "runId": { "type": "string", "minLength": 1 },
    "promptId": { "type": "string", "minLength": 1 },
    "condition": { "enum": ["vanilla", "threenative"] },
    "candidate": { "type": "string", "minLength": 1 },
    "ok": { "type": "boolean" },
    "generatedAt": { "type": "string" },
    "session": { "$ref": "session.schema.json" },
    "diagnostics": { "type": "array" },
    "artifacts": { "type": "object" },
    "metrics": { "type": "object" },
    "proof": {
      "type": "object",
      "required": ["promptId", "classification", "requiredAssertionIds", "assertions", "ok"],
      "properties": {
        "promptId": { "type": "string", "minLength": 1 },
        "classification": { "enum": ["continuity", "beyond-one-shot"] },
        "requiredAssertionIds": { "type": "array", "items": { "type": "string" } },
        "assertions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "pass"],
            "properties": {
              "id": { "type": "string" },
              "pass": { "type": "boolean" },
              "details": { "type": "object" }
            }
          }
        },
        "ok": { "type": "boolean" }
      }
    }
  }
}
