{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema": "threenative.agent-benchmark-session",
  "version": 2,
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "runId", "promptId", "condition", "tokenCount", "iterationCount", "stopReason", "humanRubric"],
  "properties": {
    "schema": { "const": "threenative.agent-benchmark-session" },
    "version": { "const": 2 },
    "runId": { "type": "string", "minLength": 1 },
    "promptId": { "type": "string", "minLength": 1 },
    "condition": { "enum": ["vanilla", "threenative", "typed-spec"] },
    "tokenCount": { "type": "number", "minimum": 0 },
    "tokenAccounting": { "const": "codex-turn-usage" },
    "inputTokens": { "type": "number", "minimum": 0 },
    "cachedInputTokens": { "type": "number", "minimum": 0 },
    "uncachedInputTokens": { "type": "number", "minimum": 0 },
    "outputTokens": { "type": "number", "minimum": 0 },
    "costWeightedTokens": { "type": "number", "minimum": 0 },
    "churnCounters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactForensics",
        "engineSourceSearch",
        "failedCommand",
        "missingDiscovery",
        "missingIterate",
        "repeatedAssertion",
        "repeatedDiagnostic",
        "repeatedFileRead",
        "standaloneVerify"
      ],
      "properties": {
        "artifactForensics": { "type": "number", "minimum": 0 },
        "engineSourceSearch": { "type": "number", "minimum": 0 },
        "failedCommand": { "type": "number", "minimum": 0 },
        "missingDiscovery": { "type": "number", "minimum": 0 },
        "missingIterate": { "type": "number", "minimum": 0 },
        "repeatedAssertion": { "type": "number", "minimum": 0 },
        "repeatedDiagnostic": { "type": "number", "minimum": 0 },
        "repeatedFileRead": { "type": "number", "minimum": 0 },
        "standaloneVerify": { "type": "number", "minimum": 0 }
      }
    },
    "toolOutputBytes": { "type": "number", "minimum": 0 },
    "failedCommandCount": { "type": "number", "minimum": 0 },
    "identicalAssertionRepeatCount": { "type": "number", "minimum": 0 },
    "maxConsecutiveSameDiagnostic": { "type": "number", "minimum": 0 },
    "toolStepCount": { "type": "number", "minimum": 0 },
    "iterationCount": { "type": "number", "minimum": 0 },
    "stopReason": { "enum": ["claimed-playable", "token-cap", "operator-stopped", "failed-setup"] },
    "finishedAt": { "type": "string" },
    "humanRubric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["playability", "visual"],
      "properties": {
        "playability": { "type": "number", "minimum": 0, "maximum": 3 },
        "visual": { "type": "number", "minimum": 0, "maximum": 3 },
        "notes": { "type": "string" }
      }
    }
  }
}
