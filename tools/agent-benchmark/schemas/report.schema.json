{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema": "threenative.agent-benchmark-report",
  "version": 2,
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "generatedAt", "runCount", "promptSummaries", "verdict", "typedSpecVerdict", "diagnostics"],
  "properties": {
    "schema": { "const": "threenative.agent-benchmark-report" },
    "version": { "const": 2 },
    "generatedAt": { "type": "string" },
    "runCount": { "type": "number", "minimum": 0 },
    "promptSummaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["promptId", "threenativeMedianTokens", "vanillaMedianTokens", "withinEqualProofTokenBudget", "withinRepeatBudget"],
        "additionalProperties": true,
        "properties": {
          "promptId": { "type": "string" },
          "threenativeMedianTokens": { "type": ["number", "null"] },
          "vanillaMedianTokens": { "type": ["number", "null"] },
          "rawTokenRatio": { "type": ["number", "null"] },
          "costWeightedTokenRatio": { "type": ["number", "null"] },
          "withinHalfX": { "type": ["boolean", "null"] },
          "withinEqualProofTokenBudget": { "type": ["boolean", "null"] },
          "withinRepeatBudget": { "type": "boolean" },
          "promptClassification": { "enum": ["continuity", "beyond-one-shot", "unknown"] },
          "repeatCount": { "type": "object" },
          "proofBar": { "type": "object" },
          "typedSpecTrial": { "type": "object" }
        }
      }
    },
    "diagnostics": { "type": "array" },
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "summary", "threshold"],
      "properties": {
        "status": { "enum": ["pass", "fail", "insufficient-data"] },
        "summary": { "type": "string" },
        "threshold": { "const": "equal-proof: continuity <=1.5x vanilla tokens; beyond-one-shot <=1.0x vanilla tokens; repeats >=3; failed commands ==0; retry chains <=1/0" }
      }
    },
    "typedSpecVerdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "summary", "threshold"],
      "properties": {
        "status": { "enum": ["default-candidate", "experimental", "insufficient-data"] },
        "summary": { "type": "string" },
        "threshold": { "const": "typed-spec: equal proof repeats >=3; median tokens <= direct ThreeNative; failed commands ==0; retry chains <=1/0" }
      }
    }
  }
}
