{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema": "threenative.agent-benchmark-report",
  "version": 2,
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "generatedAt", "runCount", "promptSummaries", "verdict", "diagnostics"],
  "properties": {
    "schema": { "const": "threenative.agent-benchmark-report" },
    "version": { "const": 2 },
    "generatedAt": { "type": "string" },
    "runCount": { "type": "number", "minimum": 0 },
    "promptSummaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["promptId", "threenativeMedianTokens", "vanillaMedianTokens", "withinHalfX"],
        "additionalProperties": true,
        "properties": {
          "promptId": { "type": "string" },
          "threenativeMedianTokens": { "type": ["number", "null"] },
          "vanillaMedianTokens": { "type": ["number", "null"] },
          "rawTokenRatio": { "type": ["number", "null"] },
          "costWeightedTokenRatio": { "type": ["number", "null"] },
          "withinHalfX": { "type": ["boolean", "null"] }
        }
      }
    },
    "diagnostics": { "type": "array" },
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "summary", "threshold"],
      "properties": {
        "status": { "enum": ["pass", "fail", "insufficient-data"] },
        "summary": { "type": "string" },
        "threshold": { "const": "threenative-median-tokens <= 0.5x vanilla-median-tokens" }
      }
    }
  }
}
