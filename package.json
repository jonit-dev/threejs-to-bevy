{
  "name": "threejs-to-bevy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "build:verify-tools": "pnpm --filter @threenative/verify-tools build",
    "check:docs": "pnpm build:verify-tools && node tools/verify/dist/cli/check-docs.js",
    "check:names": "node scripts/check-current-names.mjs",
    "check:docs:v1": "node scripts/legacy-script-alias.mjs check:docs:v1",
    "check:docs:v2": "node scripts/legacy-script-alias.mjs check:docs:v2",
    "check:docs:v3": "node scripts/legacy-script-alias.mjs check:docs:v3",
    "check:docs:v4": "node scripts/legacy-script-alias.mjs check:docs:v4",
    "check:docs:v5": "node scripts/legacy-script-alias.mjs check:docs:v5",
    "check:docs:v6": "node scripts/legacy-script-alias.mjs check:docs:v6",
    "check:docs:v7": "node scripts/legacy-script-alias.mjs check:docs:v7",
    "check:docs:v8": "node scripts/legacy-script-alias.mjs check:docs:v8",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test && node --test scripts/*.test.mjs && cargo test --manifest-path runtime-bevy/Cargo.toml",
    "tn": "pnpm --filter @threenative/sdk build && pnpm --filter @threenative/ir build && pnpm --filter @threenative/compiler build && pnpm --filter @threenative/runtime-web-three build && pnpm --filter @threenative/cli build && pnpm --filter @threenative/cli tn",
    "typecheck": "pnpm -r --if-present typecheck",
    "deploy": "node scripts/publish-distribution-release.mjs",
    "publish:distribution": "node scripts/publish-distribution-release.mjs",
    "verify": "pnpm build && pnpm typecheck && pnpm lint && pnpm test",
    "verify:all": "pnpm verify && pnpm verify:conformance",
    "verify:release": "pnpm build:verify-tools && node tools/verify/dist/cli/release.js",
    "verify:conformance": "pnpm build:verify-tools && node tools/verify/dist/cli/conformance.js",
    "verify:distribution": "node scripts/verify-distribution-release.mjs",
    "verify:v2": "node scripts/verify-v2.mjs",
    "verify:v3": "node scripts/verify-v3.mjs",
    "verify:v4": "pnpm --filter @threenative/cli build && node scripts/verify-v4.mjs",
    "verify:v5": "node scripts/verify-v5.mjs",
    "verify:v6": "node scripts/verify-v6.mjs",
    "verify:v7": "node scripts/legacy-script-alias.mjs verify:v7",
    "verify:v8:overlay": "node scripts/verify-v8-overlay-webview.mjs",
    "verify:v8:camera-views": "node scripts/verify-v8-camera-views.mjs",
    "verify:v8:color-parity": "node scripts/verify-v8-color-parity.mjs",
    "test:color-parity": "pnpm --filter @threenative/cli build && node scripts/check-color-parity-contract.mjs && node --test scripts/check-color-parity-contract.test.mjs scripts/verify-v8-color-parity.test.mjs",
    "verify:v8:material-parity": "node scripts/verify-v8-material-parity.mjs",
    "verify:v8:animation-transform": "node scripts/verify-v8-animation-transform-trace.mjs",
    "verify:v8:animation-controls": "node scripts/verify-v8-animation-controls.mjs",
    "verify:v8:rigid-body-primitive": "node scripts/verify-v8-rigid-body-primitive-trace.mjs",
    "verify:v8:asset-load-gltf-inspection": "node scripts/verify-v8-asset-load-gltf-inspection.mjs",
    "verify:v8:rendering-quality": "node scripts/verify-v8-rendering-quality.mjs",
    "verify:v9:skeletal-animation": "node scripts/verify-v9-skeletal-animation.mjs",
    "verify:v9:animation-state": "node scripts/verify-v9-animation-state.mjs",
    "verify:v9:animation-blending": "node scripts/verify-v9-animation-blending.mjs",
    "verify:v9:animation-particles": "node scripts/verify-v9-animation-particles.mjs",
    "verify:v9:physics-character": "node scripts/verify-v9-physics-character.mjs",
    "verify:v9:assets-gltf-scene-workflow": "pnpm --filter @threenative/cli build && pnpm --filter @threenative/ir build && pnpm --filter @threenative/runtime-web-three build && node scripts/verify-v9-assets-gltf-scene-workflow.mjs",
    "verify:v9:rendering-lights": "pnpm --filter @threenative/ir build && pnpm --filter @threenative/runtime-web-three build && pnpm --filter @threenative/cli build && node scripts/verify-v9-rendering-lights.mjs",
    "verify:v9": "node scripts/legacy-script-alias.mjs verify:v9",
    "check:quality:v9": "pnpm build:verify-tools && node scripts/check-v9-quality-gates.mjs",
    "verify:v10": "node scripts/verify-v10.mjs",
    "verify:v10:visual-calibration": "pnpm --filter @threenative/cli build && node scripts/verify-v10-visual-calibration.mjs",
    "verify:v10:advanced-physics": "node scripts/verify-v10-advanced-physics.mjs",
    "verify:v10:debug-draw": "node scripts/verify-v10-debug-draw.mjs",
    "verify:v10:editor-panels": "node scripts/verify-v10-editor-panels.mjs",
    "verify:v10:editor-property-editing": "node scripts/verify-v10-editor-property-editing.mjs",
    "verify:v10:editor-tools": "node scripts/verify-v10-editor-tools.mjs",
    "verify:v10:emissive-bloom": "node scripts/verify-v10-emissive-bloom.mjs",
    "verify:v10:native-instancing": "node scripts/verify-v10-native-instancing.mjs",
    "verify:v10:native-ui-effects": "node scripts/verify-v10-native-ui-effects.mjs",
    "verify:v10:native-ui-images": "node scripts/verify-v10-native-ui-images.mjs",
    "verify:v10:native-rich-text": "node scripts/verify-v10-native-rich-text.mjs",
    "verify:v10:post-antialiasing": "node scripts/verify-v10-post-antialiasing.mjs",
    "verify:v10:ecs-tags-groups": "pnpm --filter @threenative/ir test -- --run conformance && pnpm --filter @threenative/runtime-web-three test -- --run conformance && cargo test --manifest-path runtime-bevy/Cargo.toml -p threenative_runtime should_report_v10_ecs_tags",
    "verify:scene-lifecycle": "pnpm --filter @threenative/ir build && pnpm --filter @threenative/runtime-web-three build && node scripts/verify-scene-lifecycle.mjs",
    "verify:animation-physics-residuals": "pnpm --filter @threenative/ir build && pnpm --filter @threenative/runtime-web-three build && node scripts/verify-animation-physics-residuals.mjs",
    "verify:input-ui-polish": "pnpm --filter @threenative/ir build && pnpm --filter @threenative/runtime-web-three build && node scripts/verify-input-ui-polish.mjs",
    "verify:persistence-reload": "pnpm --filter @threenative/ir build && pnpm --filter @threenative/runtime-web-three build && node scripts/verify-persistence-reload.mjs"
  },
  "devDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.5"
  }
}
