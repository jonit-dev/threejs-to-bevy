{
  "name": "threejs-to-bevy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "check:docs:v1": "node scripts/check-docs-v1.mjs",
    "check:docs:v2": "node scripts/check-docs-v2.mjs",
    "check:docs:v3": "node scripts/check-docs-v3.mjs",
    "check:docs:v4": "node scripts/check-docs-v4.mjs",
    "check:docs:v5": "node scripts/check-docs-v5.mjs",
    "check:docs:v6": "node scripts/check-docs-v6.mjs",
    "check:docs:v7": "node scripts/check-docs-v7.mjs",
    "check:docs:v8": "node scripts/check-docs-v8.mjs",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test && node --test scripts/*.test.mjs",
    "tn": "pnpm --filter @threenative/sdk build && pnpm --filter @threenative/ir build && pnpm --filter @threenative/compiler build && pnpm --filter @threenative/runtime-web-three build && pnpm --filter @threenative/cli build && pnpm --filter @threenative/cli tn",
    "typecheck": "pnpm -r --if-present typecheck",
    "verify": "pnpm build && pnpm typecheck && pnpm lint && pnpm test",
    "verify:all": "pnpm verify && pnpm verify:conformance && cargo test --manifest-path runtime-bevy/Cargo.toml",
    "verify:conformance": "node scripts/verify-conformance.mjs",
    "verify:v1": "node scripts/verify-v1.mjs",
    "verify:v2": "node scripts/verify-v2.mjs",
    "verify:v3": "node scripts/verify-v3.mjs",
    "verify:v4": "pnpm --filter @threenative/cli build && node scripts/verify-v4.mjs",
    "verify:v5": "node scripts/verify-v5.mjs",
    "verify:v6": "node scripts/verify-v6.mjs",
    "verify:v7": "node scripts/verify-v7.mjs",
    "verify:v8:overlay": "node scripts/verify-v8-overlay-webview.mjs",
    "verify:v8:camera-views": "node scripts/verify-v8-camera-views.mjs",
    "verify:v8:color-parity": "node scripts/verify-v8-color-parity.mjs",
    "test:color-parity": "pnpm --filter @threenative/cli build && node scripts/check-color-parity-contract.mjs && node --test scripts/check-color-parity-contract.test.mjs scripts/verify-v8-color-parity.test.mjs",
    "verify:v8:material-parity": "node scripts/verify-v8-material-parity.mjs",
    "verify:v8:animation-transform": "node scripts/verify-v8-animation-transform-trace.mjs",
    "verify:v8:animation-controls": "node scripts/verify-v8-animation-controls.mjs",
    "verify:v8:rigid-body-primitive": "node scripts/verify-v8-rigid-body-primitive-trace.mjs",
    "verify:v8:asset-load-gltf-inspection": "node scripts/verify-v8-asset-load-gltf-inspection.mjs",
    "verify:v8:rendering-quality": "node scripts/verify-v8-rendering-quality.mjs",
    "verify:v9:skeletal-animation": "node scripts/verify-v9-skeletal-animation.mjs",
    "verify:v9:animation-state": "node scripts/verify-v9-animation-state.mjs",
    "verify:v9:animation-blending": "node scripts/verify-v9-animation-blending.mjs",
    "verify:v9:animation-particles": "node scripts/verify-v9-animation-particles.mjs",
    "verify:v9:physics-character": "node scripts/verify-v9-physics-character.mjs",
    "verify:v9:assets-gltf-scene-workflow": "pnpm --filter @threenative/cli build && pnpm --filter @threenative/ir build && pnpm --filter @threenative/runtime-web-three build && node scripts/verify-v9-assets-gltf-scene-workflow.mjs",
    "verify:v9:rendering-lights": "pnpm --filter @threenative/ir build && pnpm --filter @threenative/runtime-web-three build && pnpm --filter @threenative/cli build && node scripts/verify-v9-rendering-lights.mjs",
    "verify:v9:diagnostics-support": "node scripts/verify-v9-diagnostics-support.mjs"
  },
  "devDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.5"
  }
}
