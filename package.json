{
  "name": "threejs-to-bevy",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "build:verify-tools": "pnpm --filter @threenative/verify-tools build",
    "check:asset-sources": "node scripts/build-asset-source-catalog.mjs --check",
    "check:docs": "pnpm build:verify-tools && node tools/verify/dist/cli/check-docs.js",
    "check:names": "node scripts/check-current-names.mjs",
    "lint": "pnpm -r --if-present lint",
    "test": "node scripts/run-root-tests.mjs",
    "test:color-parity": "pnpm --filter @threenative/cli build && node scripts/check-color-parity-contract.mjs && node --test scripts/check-color-parity-contract.test.mjs scripts/verify-v8-color-parity.test.mjs",
    "tn": "pnpm --filter @threenative/sdk build && pnpm --filter @threenative/ir build && pnpm --filter @threenative/authoring build && pnpm --filter @threenative/compiler build && pnpm --filter @threenative/runtime-web-three build && pnpm --filter @threenative/cli build && pnpm --filter @threenative/cli tn",
    "typecheck": "pnpm -r --if-present typecheck",
    "deploy": "node scripts/publish-distribution-release.mjs",
    "publish:distribution": "node scripts/publish-distribution-release.mjs",
    "verify": "pnpm build && pnpm typecheck && pnpm lint && pnpm test",
    "verify:alias": "node scripts/legacy-script-alias.mjs",
    "verify:all": "pnpm verify && pnpm verify:conformance",
    "verify:changed": "pnpm verify",
    "verify:conformance": "pnpm build:verify-tools && node tools/verify/dist/cli/conformance.js",
    "verify:distribution": "node scripts/verify-distribution-release.mjs",
    "verify:editor-required-operations": "node scripts/verify-editor-required-operations.mjs",
    "verify:focused": "pnpm build:verify-tools && node tools/verify/dist/cli/run.js",
    "verify:game-production": "pnpm build:verify-tools && node tools/verify/dist/cli/run.js verify:game-production",
    "verify:generated-games": "pnpm build:verify-tools && node tools/verify/dist/cli/run.js verify:generated-games",
    "verify:gltf-fidelity": "pnpm build:verify-tools && node --test tools/verify/dist/gltfFidelity.test.js",
    "verify:full": "pnpm verify:all && pnpm verify:release",
    "verify:parity:push": "node scripts/verify-parity-push.mjs",
    "verify:parity:smoke": "node scripts/verify-parity-smoke.mjs",
    "verify:pre-push": "node scripts/verify-pre-push.mjs",
    "verify:physics-self-verification": "pnpm build:verify-tools && node tools/verify/dist/cli/run.js verify:physics-self-verification",
    "verify:release": "pnpm build:verify-tools && node tools/verify/dist/cli/release.js",
    "verify:render-look": "pnpm --filter @threenative/compiler build && pnpm --filter @threenative/runtime-web-three build && pnpm --filter @threenative/cli build && pnpm build:verify-tools && node tools/verify/dist/cli/renderLook.js",
    "verify:runtime-gameplay-host": "pnpm build:verify-tools && node tools/verify/dist/cli/run.js verify:runtime-gameplay-host",
    "verify:runtime-prefabs-hierarchy": "pnpm build:verify-tools && node tools/verify/dist/cli/run.js verify:runtime-prefabs-hierarchy",
    "verify:runtime-query-diffing": "pnpm build:verify-tools && node tools/verify/dist/cli/run.js verify:runtime-query-diffing",
    "verify:scripting-helpers-lifecycle": "pnpm build:verify-tools && node tools/verify/dist/cli/run.js verify:scripting-helpers-lifecycle",
    "verify:template-production": "pnpm build:verify-tools && node tools/verify/dist/cli/run.js verify:template-production",
    "verify:template-playability": "pnpm build:verify-tools && node tools/verify/dist/cli/run.js verify:template-playability",
    "verify:ui-persistence-settings-facades": "pnpm build:verify-tools && node tools/verify/dist/cli/run.js verify:ui-persistence-settings-facades",
    "verify:smoke": "pnpm check:names && pnpm check:docs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.4.0",
    "@gltf-transform/core": "^4.4.0",
    "@gltf-transform/extensions": "^4.4.0",
    "husky": "^9.1.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.5"
  }
}
