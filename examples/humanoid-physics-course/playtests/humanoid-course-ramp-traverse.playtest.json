{
  "schemaVersion": 1,
  "name": "humanoid-course-ramp-traverse",
  "target": "web",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "subject": "player",
  "setup": {
    "entities": [
      {
        "entity": "player",
        "position": [
          2.15,
          0,
          3.95
        ]
      }
    ]
  },
  "warmupFrames": 5,
  "steps": [
    {
      "label": "walk-up-authored-ramp",
      "press": "KeyW",
      "holdFrames": 24,
      "release": true
    }
  ],
  "assert": {
    "movement": {
      "entity": "player",
      "axis": "-z",
      "minDistance": 1,
      "minResolvedAxisDelta": {
        "axis": "+y",
        "min": 0.4
      }
    },
    "contacts": [
      {
        "entity": "player",
        "with": "ramp.main",
        "minCount": 1
      }
    ],
    "diagnostics": {
      "runtimeReady": true,
      "noConsoleErrors": true,
      "noNetworkErrors": true,
      "noRuntimeDiagnostics": true
    }
  },
  "artifacts": {
    "screenshots": "before-after",
    "console": true,
    "network": true,
    "runtimeTrace": true,
    "effectLog": "focused"
  }
}
