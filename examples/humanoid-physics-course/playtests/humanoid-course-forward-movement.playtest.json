{
  "schemaVersion": 1,
  "name": "humanoid-course-forward-movement",
  "target": "web",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "subject": "player",
  "parity": {
    "targets": ["web", "desktop"],
    "compare": {
      "movementDistance": { "maxDelta": 2.0 },
      "axisDelta": { "z": 2.0, "y": 0.08 }
    }
  },
  "warmupFrames": 0,
  "steps": [
    {
      "press": "KeyW",
      "holdFrames": 30,
      "release": true
    }
  ],
  "assert": {
    "movement": {
      "entity": "player",
      "axis": "-z",
      "minDistance": 0.01
    },
    "diagnostics": {
      "noConsoleErrors": true,
      "noNetworkErrors": true,
      "noRuntimeDiagnostics": true,
      "runtimeReady": true
    }
  },
  "artifacts": {
    "screenshots": "before-after",
    "effectLog": "focused",
    "runtimeTrace": true,
    "console": true,
    "network": true
  }
}
