{
  "schemaVersion": 1,
  "name": "humanoid-course-jump",
  "target": "desktop",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "subject": "player",
  "warmupFrames": 5,
  "steps": [
    {
      "label": "grounded-jump",
      "press": "Space",
      "holdFrames": 12,
      "release": true
    }
  ],
  "assert": {
    "movement": {
      "entity": "player",
      "minAxisDelta": {
        "axis": "+y",
        "min": 0.3
      }
    },
    "diagnostics": {
      "runtimeReady": true,
      "noConsoleErrors": true,
      "noNetworkErrors": true,
      "noRuntimeDiagnostics": true
    }
  },
  "artifacts": {
    "screenshots": "before-after",
    "console": true,
    "network": true,
    "runtimeTrace": true,
    "effectLog": "focused"
  }
}
