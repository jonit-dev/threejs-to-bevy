{
  "schema": "threenative.input",
  "version": "0.1.0",
  "id": "arena-input",
  "actions": [
    { "id": "move-left", "bindings": ["keyboard.KeyA", "keyboard.ArrowLeft"] },
    { "id": "move-right", "bindings": ["keyboard.KeyD", "keyboard.ArrowRight"] },
    { "id": "move-forward", "bindings": ["keyboard.KeyW", "keyboard.ArrowUp"] },
    { "id": "move-back", "bindings": ["keyboard.KeyS", "keyboard.ArrowDown"] },
    { "id": "sprint", "bindings": ["keyboard.ShiftLeft", "keyboard.ShiftRight"] },
    { "id": "retry", "bindings": ["keyboard.KeyR"] }
  ],
  "axes": [
    { "id": "MoveX", "negative": ["keyboard.KeyA", "keyboard.ArrowLeft"], "positive": ["keyboard.KeyD", "keyboard.ArrowRight"] },
    { "id": "MoveZ", "negative": ["keyboard.KeyW", "keyboard.ArrowUp"], "positive": ["keyboard.KeyS", "keyboard.ArrowDown"] },
    { "id": "LookX", "negative": [], "positive": [], "value": "pointer.deltaX" },
    { "id": "LookY", "negative": [], "positive": [], "value": "pointer.deltaY" }
  ]
}
