{
  "schema": "threenative.systems",
  "version": "0.1.0",
  "id": "arena-systems",
  "systems": [
    {
      "id": "humanoid-course",
      "schedule": "fixedUpdate",
      "reads": [
        "Checkpoint",
        "FinishZone",
        "KinematicMover"
      ],
      "writes": [
        "CoursePlayer",
        "RigidBody",
        "Transform"
      ],
      "resourceReads": [
        "GameState",
        "tn.characterRig.player",
        "tn.triggerCooldown.hazard.sweeper.01",
        "tn.triggerCooldown.hazard.sweeper.02",
        "tn.triggerEx.checkpoint.01",
        "tn.triggerEx.checkpoint.02",
        "tn.triggerEx.finish.pad",
        "tn.triggerEx.hazard.sweeper.01",
        "tn.triggerEx.hazard.sweeper.02"
      ],
      "resourceWrites": [
        "GameState",
        "tn.characterRig.player",
        "tn.triggerCooldown.hazard.sweeper.01",
        "tn.triggerCooldown.hazard.sweeper.02",
        "tn.triggerEx.checkpoint.01",
        "tn.triggerEx.checkpoint.02",
        "tn.triggerEx.finish.pad",
        "tn.triggerEx.hazard.sweeper.01",
        "tn.triggerEx.hazard.sweeper.02"
      ],
      "services": [
        "character.move",
        "animation.play",
        "physics.sensor"
      ],
      "script": {
        "module": "src/scripts/player.ts",
        "export": "updateHumanoidCourse"
      }
    },
    {
      "id": "third-person-camera",
      "schedule": "postUpdate",
      "reads": [
        "CoursePlayer",
        "Transform"
      ],
      "writes": [
        "Transform"
      ],
      "resourceReads": [
        "GameState",
        "tn.cameraRig.camera.main"
      ],
      "resourceWrites": [
        "GameState",
        "tn.cameraRig.camera.main"
      ],
      "script": {
        "module": "src/scripts/player.ts",
        "export": "updateThirdPersonCamera"
      }
    }
  ]
}
