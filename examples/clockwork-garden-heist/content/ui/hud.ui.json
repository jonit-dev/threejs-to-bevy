{
  "schema": "threenative.ui",
  "version": "0.1.0",
  "id": "hud",
  "nodes": [
    {
      "id": "loot",
      "type": "text",
      "text": "Gems 0/3 | Key 0/1",
      "style": { "color": "#f5fff4", "fontSize": 24, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 26, "width": 1280 }
    },
    {
      "id": "timer",
      "type": "text",
      "text": "Time 70",
      "style": { "color": "#f5fff4", "fontSize": 22, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 62, "width": 1280 }
    },
    {
      "id": "status",
      "type": "text",
      "text": "Steal the gems and key, then slip through the moon gate",
      "style": { "color": "#ffffff", "fontSize": 19, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "bottom", "top": 676, "width": 1280 }
    }
    ,
    { "id": "state.loading", "type": "text", "text": "Loading clockwork garden", "layout": { "justify": "center", "align": "center", "top": 1200, "width": 1280 } },
    { "id": "state.pause", "type": "text", "text": "Paused", "layout": { "justify": "center", "align": "center", "top": 1230, "width": 1280 } },
    { "id": "state.settings", "type": "text", "text": "Settings", "layout": { "justify": "center", "align": "center", "top": 1260, "width": 1280 } },
    { "id": "state.fail-retry", "type": "text", "text": "Caught - press Space", "layout": { "justify": "center", "align": "center", "top": 1290, "width": 1280 } },
    { "id": "state.win-milestone", "type": "text", "text": "Moon gate cleared", "layout": { "justify": "center", "align": "center", "top": 1320, "width": 1280 } },
    { "id": "state.touch-controls", "type": "text", "text": "Touch automaton mobile-control", "layout": { "justify": "center", "align": "center", "top": 1350, "width": 1280 } }
  ],
  "bindings": [
    { "node": "loot", "resource": "GameState.lootText" },
    { "node": "timer", "resource": "GameState.timerText" },
    { "node": "status", "resource": "GameState.status" }
  ]
}
