{
  "schemaVersion": 1,
  "name": "aerodynamics-flight-course-objective",
  "subject": "craft",
  "parity": {
    "targets": ["web", "desktop"],
    "compare": {
      "movementDistance": { "maxDelta": 30 },
      "resources": [
        "FlightState.takeoff",
        "FlightState.gust",
        "FlightState.stall",
        "FlightState.recovered",
        "FlightState.landed",
        "FlightState.objectiveStep",
        "FlightState.events",
        "FlightState.retryCount"
      ]
    }
  },
  "setup": {
    "entities": [
      { "entity": "craft", "position": [0, 2, 8], "rotation": [0, 0, 0, 1] }
    ]
  },
  "steps": [
    { "label": "runway", "waitTicks": 20, "screenshot": "01-runway" },
    { "label": "retry", "press": "KeyR", "holdTicks": 1, "release": true, "screenshot": "02-retry" },
    { "label": "milestones-1-2-takeoff-and-gust", "press": "KeyW", "holdTicks": 90, "release": true, "screenshot": "03-takeoff" },
    { "label": "milestone-3-stall", "press": "ArrowUp", "holdTicks": 40, "release": true, "screenshot": "04-stall" },
    { "label": "milestone-4-recovery", "press": "ArrowDown", "holdTicks": 40, "release": true, "screenshot": "05-recovery" },
    { "label": "milestone-5-landing", "waitTicks": 100, "screenshot": "06-landing" }
  ],
  "assert": {
    "movement": { "entity": "craft", "minDistance": 5, "maxDistance": 300 },
    "resources": [
      { "id": "FlightState", "path": "takeoff", "equals": true, "changed": true },
      { "id": "FlightState", "path": "gust", "equals": true, "changed": true },
      { "id": "FlightState", "path": "stall", "equals": true, "changed": true },
      { "id": "FlightState", "path": "recovered", "equals": true, "changed": true },
      { "id": "FlightState", "path": "landed", "equals": true, "changed": true },
      { "id": "FlightState", "path": "objectiveStep", "equals": 5, "changed": true },
      { "id": "FlightState", "path": "events", "equals": ["retry", "takeoff", "gust", "stall", "recovery", "landing"], "changed": true },
      { "id": "FlightState", "path": "retryCount", "gte": 1, "changed": true }
    ],
    "diagnostics": {
      "runtimeReady": true,
      "noConsoleErrors": true,
      "noNetworkErrors": true,
      "noRuntimeDiagnostics": true
    }
  },
  "artifacts": {
    "screenshots": "per-step",
    "console": true,
    "network": true,
    "runtimeTrace": true,
    "effectLog": "focused"
  }
}
