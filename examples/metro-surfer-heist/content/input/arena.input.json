{
  "schema": "threenative.input",
  "version": "0.1.0",
  "id": "arena-input",
  "actions": [
    { "id": "move-left", "bindings": ["keyboard.KeyA", "keyboard.ArrowLeft"] },
    { "id": "move-right", "bindings": ["keyboard.KeyD", "keyboard.ArrowRight"] },
    { "id": "jump", "bindings": ["keyboard.KeyW", "keyboard.ArrowUp", "keyboard.Space"] },
    { "id": "duck", "bindings": ["keyboard.KeyS", "keyboard.ArrowDown"] },
    { "id": "retry", "bindings": ["keyboard.KeyR", "keyboard.Enter"] }
  ]
}
