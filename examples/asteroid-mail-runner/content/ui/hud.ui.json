{
  "schema": "threenative.ui",
  "version": "0.1.0",
  "id": "hud",
  "nodes": [
    {
      "id": "route",
      "type": "text",
      "text": "Rings 0/3",
      "style": { "color": "#f7fbff", "fontSize": 24, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 24, "width": 1280 }
    },
    {
      "id": "cargo",
      "type": "text",
      "text": "Data 0/4",
      "style": { "color": "#ffdf7b", "fontSize": 22, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 58, "width": 1280 }
    },
    {
      "id": "fuel",
      "type": "text",
      "text": "Fuel 75",
      "style": { "color": "#8eeaff", "fontSize": 22, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 90, "width": 1280 }
    },
    {
      "id": "status",
      "type": "text",
      "text": "Data, rings, beacon",
      "style": { "color": "#ffffff", "fontSize": 16, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 122, "width": 1280 }
    },
    { "id": "state.loading", "type": "text", "text": "Loading asteroid route", "layout": { "justify": "center", "align": "center", "top": 1200, "width": 1280 } },
    { "id": "state.pause", "type": "text", "text": "Paused", "layout": { "justify": "center", "align": "center", "top": 1230, "width": 1280 } },
    { "id": "state.settings", "type": "text", "text": "Settings", "layout": { "justify": "center", "align": "center", "top": 1260, "width": 1280 } },
    { "id": "state.fail-retry", "type": "text", "text": "Courier lost - press Space", "layout": { "justify": "center", "align": "center", "top": 1290, "width": 1280 } },
    { "id": "state.win-milestone", "type": "text", "text": "Beacon mail delivered", "layout": { "justify": "center", "align": "center", "top": 1320, "width": 1280 } },
    { "id": "state.touch-controls", "type": "text", "text": "Touch courier controls mobile-control", "layout": { "justify": "center", "align": "center", "top": 1350, "width": 1280 } }
  ],
  "bindings": [
    { "node": "route", "resource": "GameState.ringText" },
    { "node": "cargo", "resource": "GameState.cargoText" },
    { "node": "fuel", "resource": "GameState.fuelText" },
    { "node": "status", "resource": "GameState.status" }
  ]
}
