{
  "schema": "threenative.systems",
  "version": "0.1.0",
  "id": "lane-systems",
  "systems": [
    {
      "id": "bowling.lane",
      "schedule": "fixedUpdate",
      "queries": [
        {
          "with": [
            "Transform"
          ],
          "orderBy": "id"
        }
      ],
      "reads": [
        "Transform",
        "BowlingBall",
        "Pin"
      ],
      "writes": [
        "Transform",
        "BowlingBall",
        "Pin"
      ],
      "resourceWrites": [
        "BowlingState"
      ],
      "script": {
        "module": "src/scripts/bowling.ts",
        "export": "bowlingLaneSystem"
      }
    }
  ]
}
