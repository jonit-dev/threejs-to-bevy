{
  "schema": "threenative.input",
  "version": "0.1.0",
  "id": "lane-input",
  "actions": [
    {
      "id": "aim-left",
      "bindings": [
        "keyboard.KeyA",
        "keyboard.ArrowLeft"
      ]
    },
    {
      "id": "aim-right",
      "bindings": [
        "keyboard.KeyD",
        "keyboard.ArrowRight"
      ]
    },
    {
      "id": "roll",
      "bindings": [
        "keyboard.Space",
        "keyboard.Enter"
      ]
    },
    {
      "id": "reset",
      "bindings": [
        "keyboard.KeyR"
      ]
    }
  ]
}
