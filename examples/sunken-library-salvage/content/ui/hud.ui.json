{
  "schema": "threenative.ui",
  "version": "0.1.0",
  "id": "hud",
  "nodes": [
    {
      "id": "relics",
      "type": "text",
      "text": "Relics 0/3",
      "style": { "color": "#e8fbff", "fontSize": 24, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 26, "width": 1280 }
    },
    {
      "id": "oxygen",
      "type": "text",
      "text": "Oxygen 72",
      "style": { "color": "#e8fbff", "fontSize": 22, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 62, "width": 1280 }
    },
    {
      "id": "status",
      "type": "text",
      "text": "Recover 3 relics, then return to the air bell",
      "style": { "color": "#ffffff", "fontSize": 19, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "bottom", "top": 676, "width": 1280 }
    }
    ,
    { "id": "state.loading", "type": "text", "text": "Loading sunken archive", "layout": { "justify": "center", "align": "center", "top": 1200, "width": 1280 } },
    { "id": "state.pause", "type": "text", "text": "Paused", "layout": { "justify": "center", "align": "center", "top": 1230, "width": 1280 } },
    { "id": "state.settings", "type": "text", "text": "Settings", "layout": { "justify": "center", "align": "center", "top": 1260, "width": 1280 } },
    { "id": "state.fail-retry", "type": "text", "text": "Dive failed - press Space", "layout": { "justify": "center", "align": "center", "top": 1290, "width": 1280 } },
    { "id": "state.win-milestone", "type": "text", "text": "Archive salvage complete", "layout": { "justify": "center", "align": "center", "top": 1320, "width": 1280 } },
    { "id": "state.touch-controls", "type": "text", "text": "Touch diver mobile-control", "layout": { "justify": "center", "align": "center", "top": 1350, "width": 1280 } }
  ],
  "bindings": [
    { "node": "relics", "resource": "GameState.relicText" },
    { "node": "oxygen", "resource": "GameState.oxygenText" },
    { "node": "status", "resource": "GameState.status" }
  ]
}
