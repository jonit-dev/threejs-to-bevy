{
  "name": "tidepool-crab-courier",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tn build --project .",
    "dev:web": "tn dev --target web --project .",
    "validate": "tn validate --project .",
    "verify": "tn verify --project . --frames 3 --expect-motion",
