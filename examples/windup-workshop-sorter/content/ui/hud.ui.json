{
  "schema": "threenative.ui",
  "version": "0.1.0",
  "id": "hud",
  "nodes": [
    {
      "id": "gears",
      "type": "text",
      "text": "Gears 0/5",
      "style": { "color": "#ffe186", "fontSize": 24, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 24, "width": 1280 }
    },
    {
      "id": "bays",
      "type": "text",
      "text": "Bays 0/3",
      "style": { "color": "#92ffd9", "fontSize": 22, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 58, "width": 1280 }
    },
    {
      "id": "clock",
      "type": "text",
      "text": "Clock 78",
      "style": { "color": "#f7efe2", "fontSize": 22, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 90, "width": 1280 }
    },
    {
      "id": "status",
      "type": "text",
      "text": "Gather gears",
      "style": { "color": "#ffffff", "fontSize": 16, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 122, "width": 1280 }
    },
    { "id": "state.loading", "type": "text", "text": "Loading workshop", "layout": { "justify": "center", "align": "center", "top": 1200, "width": 1280 } },
    { "id": "state.pause", "type": "text", "text": "Paused", "layout": { "justify": "center", "align": "center", "top": 1230, "width": 1280 } },
    { "id": "state.settings", "type": "text", "text": "Settings", "layout": { "justify": "center", "align": "center", "top": 1260, "width": 1280 } },
    { "id": "state.fail-retry", "type": "text", "text": "Marble crash - press Space", "layout": { "justify": "center", "align": "center", "top": 1290, "width": 1280 } },
    { "id": "state.win-milestone", "type": "text", "text": "Toy repaired", "layout": { "justify": "center", "align": "center", "top": 1320, "width": 1280 } },
    { "id": "state.touch-controls", "type": "text", "text": "Touch mouse controls mobile-control", "layout": { "justify": "center", "align": "center", "top": 1350, "width": 1280 } }
  ],
  "bindings": [
    { "node": "gears", "resource": "GameState.gearText" },
    { "node": "bays", "resource": "GameState.bayText" },
    { "node": "clock", "resource": "GameState.clockText" },
    { "node": "status", "resource": "GameState.status" }
  ]
}
