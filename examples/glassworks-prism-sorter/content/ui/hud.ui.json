{
  "schema": "threenative.ui",
  "version": "0.1.0",
  "id": "hud",
  "nodes": [
    {
      "id": "prisms",
      "type": "text",
      "text": "Prisms 0/5",
      "style": { "color": "#ffe071", "fontSize": 24, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 24, "width": 1280 }
    },
    {
      "id": "pedestals",
      "type": "text",
      "text": "Pedestals 0/3",
      "style": { "color": "#90e7ff", "fontSize": 22, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 58, "width": 1280 }
    },
    {
      "id": "heat",
      "type": "text",
      "text": "Heat 80",
      "style": { "color": "#fff6df", "fontSize": 22, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 90, "width": 1280 }
    },
    {
      "id": "status",
      "type": "text",
      "text": "Gather prisms",
      "style": { "color": "#ffffff", "fontSize": 16, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 122, "width": 1280 }
    },
    { "id": "state.loading", "type": "text", "text": "Loading kiln floor", "layout": { "justify": "center", "align": "center", "top": 1200, "width": 1280 } },
    { "id": "state.pause", "type": "text", "text": "Pause", "layout": { "justify": "center", "align": "center", "top": 1230, "width": 1280 } },
    { "id": "state.settings", "type": "text", "text": "Settings", "layout": { "justify": "center", "align": "center", "top": 1260, "width": 1280 } },
    { "id": "state.fail-retry", "type": "text", "text": "Heat crack - Space to retry", "layout": { "justify": "center", "align": "center", "top": 1290, "width": 1280 } },
    { "id": "state.win-milestone", "type": "text", "text": "Glass sorted", "layout": { "justify": "center", "align": "center", "top": 1320, "width": 1280 } },
    { "id": "state.touch-controls", "type": "text", "text": "Touch mobile-control joystick", "layout": { "justify": "center", "align": "center", "top": 1350, "width": 1280 } }
  ],
  "bindings": [
    { "node": "prisms", "resource": "GameState.prismText" },
    { "node": "pedestals", "resource": "GameState.pedestalText" },
    { "node": "heat", "resource": "GameState.heatText" },
    { "node": "status", "resource": "GameState.status" }
  ]
}
