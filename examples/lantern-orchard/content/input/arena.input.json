{
  "schema": "threenative.input",
  "version": "0.1.0",
  "id": "arena-input",
  "actions": [
    {
      "id": "move-left",
      "bindings": [
        "keyboard.KeyA",
        "keyboard.ArrowLeft"
      ]
    },
    {
      "id": "move-right",
      "bindings": [
        "keyboard.KeyD",
        "keyboard.ArrowRight"
      ]
    },
    {
      "id": "move-up",
      "bindings": [
        "keyboard.KeyW",
        "keyboard.ArrowUp"
      ]
    },
    {
      "id": "move-down",
      "bindings": [
        "keyboard.KeyS",
        "keyboard.ArrowDown"
      ]
    },
    {
      "id": "dash",
      "bindings": [
        "keyboard.Space"
      ]
    }
  ]
}
