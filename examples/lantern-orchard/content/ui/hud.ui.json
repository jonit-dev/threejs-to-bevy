{
  "schema": "threenative.ui",
  "version": "0.1.0",
  "id": "hud",
  "nodes": [
    {
      "id": "countdown",
      "type": "text",
      "text": "Lanterns 0/8",
      "style": {
        "color": "#fff7d7",
        "fontSize": 24,
        "fontWeight": "bold",
        "textAlign": "center"
      },
      "layout": {
        "justify": "center",
        "align": "center",
        "top": 32,
        "width": 1280
      }
    },
    {
      "id": "timer",
      "type": "text",
      "text": "Time 45",
      "style": {
        "color": "#fff7d7",
        "fontSize": 20,
        "fontWeight": "bold",
        "textAlign": "left"
      },
      "layout": {
        "justify": "flex-start",
        "align": "center",
        "top": 32,
        "width": 420
      }
    },
    {
      "id": "status",
      "type": "text",
      "text": "Gather every lantern before the shadows catch you",
      "style": {
        "color": "#ffffff",
        "fontSize": 18,
        "fontWeight": "bold",
        "textAlign": "center"
      },
      "layout": {
        "justify": "center",
        "align": "center",
        "top": 92,
        "width": 1280
      }
    },
    {
      "id": "state.loading",
      "type": "text",
      "text": "Loading orchard",
      "layout": {
        "justify": "center",
        "align": "center",
        "top": 1200,
        "width": 1280
      }
    },
    {
      "id": "state.pause",
      "type": "text",
      "text": "Paused",
      "layout": {
        "justify": "center",
        "align": "center",
        "top": 1230,
        "width": 1280
      }
    },
    {
      "id": "state.settings",
      "type": "text",
      "text": "Settings",
      "layout": {
        "justify": "center",
        "align": "center",
        "top": 1260,
        "width": 1280
      }
    },
    {
      "id": "state.fail-retry",
      "type": "text",
      "text": "Retry",
      "layout": {
        "justify": "center",
        "align": "center",
        "top": 1290,
        "width": 1280
      }
    },
    {
      "id": "state.win-milestone",
      "type": "text",
      "text": "Victory milestone complete",
      "layout": {
        "justify": "center",
        "align": "center",
        "top": 1320,
        "width": 1280
      }
    },
    {
      "id": "state.touch-controls",
      "type": "text",
      "text": "Touch joystick mobile-control",
      "layout": {
        "justify": "center",
        "align": "center",
        "top": 1350,
        "width": 1280
      }
    }
  ],
  "bindings": [
    {
      "node": "countdown",
      "resource": "GameState.scoreText"
    },
    {
      "node": "timer",
      "resource": "GameState.timerText"
    },
    {
      "node": "status",
      "resource": "GameState.status"
    }
  ]
}
