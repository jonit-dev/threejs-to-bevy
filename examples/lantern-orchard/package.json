  "scripts": {
    "build": "node ../../packages/cli/dist/index.js build",
    "dev:web": "node ../../packages/cli/dist/index.js dev --target web",
    "playtest": "tn playtest --scenario playtests/smoke-movement.playtest.json --stable-artifacts --json",
    "playtest:native": "tn playtest --scenario playtests/native-smoke-movement.playtest.json --stable-artifacts --json",
    "game:score": "node ../../packages/cli/dist/index.js game score --project . --json",
    "game:qa": "node ../../packages/cli/dist/index.js game qa --project . --json",
    "game:release": "node ../../packages/cli/dist/index.js game release --project . --json",
    "recipe:controller": "node ../../packages/cli/dist/index.js recipe third-person-controller --scene arena --entity player --camera camera.main --dry-run --json",
    "validate": "node ../../packages/cli/dist/index.js validate",
    "validate:authoring": "node ../../packages/cli/dist/index.js authoring validate --json",
    "verify": "node ../../packages/cli/dist/index.js verify --frames 4 --expect-motion --json"
  },
  "dependencies": {
    "@threenative/script-stdlib": "file:/home/joao/projects/threejs-to-bevy/packages/script-stdlib",
