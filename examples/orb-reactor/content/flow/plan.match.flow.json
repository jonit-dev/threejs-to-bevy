{
  "id": "plan.match",
  "initial": "ready",
  "scene": "arena",
  "schema": "threenative.flow",
  "states": [
    {
      "id": "ready"
    },
    {
      "id": "playing"
    },
    {
      "id": "won"
    },
    {
      "id": "lost"
    }
  ],
  "transitions": [
    {
      "id": "start",
      "from": "ready",
      "to": "playing",
      "trigger": {
        "kind": "resourceEquals",
        "resource": "Match.started",
        "target": true
      }
    },
    {
      "id": "win",
      "from": "playing",
      "to": "won",
      "trigger": {
        "event": "match.win",
        "kind": "event"
      }
    },
    {
      "id": "lose",
      "from": "playing",
      "to": "lost",
      "trigger": {
        "kind": "resourceEquals",
        "resource": "Match.outcome",
        "target": "lost"
      }
    }
  ],
  "version": "0.1.0"
}
