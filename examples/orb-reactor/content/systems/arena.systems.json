{
  "schema": "threenative.systems",
  "version": "0.1.0",
  "id": "arena-systems",
  "systems": [
    {
      "id": "move-player",
      "source": "behavior-metadata",
      "script": {
        "module": "src/scripts/player.ts",
        "export": "movePlayer"
      }
    },
    {
      "id": "drone-contacts",
      "source": "behavior-metadata",
      "script": {
        "module": "src/scripts/drones.ts",
        "export": "droneContacts"
      }
    },
    {
      "id": "meltdown-timer",
      "source": "behavior-metadata",
      "script": {
        "module": "src/scripts/timer.ts",
        "export": "meltdownTimer"
      }
    }
  ],
  "countdowns": [
    {
      "autostart": true,
      "direction": "down",
      "event": "RoundTimer.limit",
      "field": "remaining",
      "id": "RoundTimer.countdown",
      "limit": 45,
      "resource": "RoundTimer"
    }
  ]
}
