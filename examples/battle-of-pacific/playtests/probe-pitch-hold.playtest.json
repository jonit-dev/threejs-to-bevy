{
  "schemaVersion": 1,
  "acceptanceId": "probe-pitch-hold",
  "name": "probe-pitch-hold",
  "target": "web",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "subject": "aircraft",
  "warmupFrames": 10,
  "steps": [
    {
      "label": "hold pitch up",
      "press": "KeyW",
      "holdFrames": 90,
      "release": true
    },
    {
      "label": "observe",
      "waitTicks": 60
    }
  ],
  "assert": {
    "movement": {
      "entity": "aircraft",
      "minDistance": 10,
      "maxDistance": 100000
    },
    "resources": [
      {
        "id": "FlightState",
        "path": "altitudeFeet",
        "gte": 250
      }
    ]
  },
  "artifacts": {
    "screenshots": "none",
    "console": false,
    "network": false,
    "runtimeTrace": true,
    "effectLog": "focused"
  }
}