    "resources": [
      {
        "id": "FlightState",
        "path": "phase",
        "equals": "PATROL COMPLETE"
      },
      {
        "id": "FlightState",
        "path": "airspeedKnots",
        "gte": 160
      }
    ]
  },
  "artifacts": {
    "screenshots": "none",
    "console": true,
    "network": true,
    "runtimeTrace": true,
    "effectLog": "focused"
