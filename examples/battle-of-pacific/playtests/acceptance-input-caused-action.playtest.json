{
  "schemaVersion": 1,
  "acceptanceId": "input-caused-action",
  "name": "acceptance-input-caused-action",
  "target": "web",
  "inputDelivery": "focused-dom",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "subject": "aircraft",
  "warmupFrames": 10,
  "steps": [
    {
      "label": "deploy powered dive flaps",
      "press": "KeyF",
      "holdTicks": 1,
      "release": true,
      "screenshot": "01-flaps-command"
    },
    {
      "label": "observe powered flap animation",
      "waitTicks": 20,
      "screenshot": "02-flaps-moving"
    }
  ],
  "assert": {
    "animation": [
      {
        "entity": "aircraft.visual",
        "clip": "flight.flaps",
        "entered": true,
        "advancedFrames": 5
      }
    ],
    "movement": {
      "entity": "aircraft",
      "minDistance": 1,
      "minVelocity": 1
    },
    "resources": [
      {
        "id": "FlightState",
        "path": "flaps",
        "equals": "DOWN",
        "changed": true
      }
    ],
    "diagnostics": {
      "runtimeReady": true,
      "noConsoleErrors": true,
      "noNetworkErrors": true,
      "noRuntimeDiagnostics": true
    },
    "visual": [
      {
        "entityVisible": {
          "entity": "aircraft.visual",
          "minProjectedPixels": 500
        }
      }
    ]
  },
  "artifacts": {
    "screenshots": "per-step",
    "console": true,
    "network": true,
    "runtimeTrace": true,
    "effectLog": "focused"
  }
}
