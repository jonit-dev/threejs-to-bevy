{
  "schema": "threenative.ui",
  "version": "0.1.0",
  "id": "hud",
  "nodes": [
    {
      "id": "ingredients",
      "type": "text",
      "text": "Ingredients 0/5",
      "style": { "color": "#fff2cf", "fontSize": 24, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 32, "width": 1280 }
    },
    {
      "id": "timer",
      "type": "text",
      "text": "Time 60",
      "style": { "color": "#fff2cf", "fontSize": 22, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 68, "width": 1280 }
    },
    {
      "id": "status",
      "type": "text",
      "text": "Collect 5 crates, then deliver to the chef",
      "style": { "color": "#ffffff", "fontSize": 20, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "bottom", "top": 650, "width": 1280 }
    },
    { "id": "state.loading", "type": "text", "text": "Loading market", "layout": { "justify": "center", "align": "center", "top": 1200, "width": 1280 } },
    { "id": "state.pause", "type": "text", "text": "Paused", "layout": { "justify": "center", "align": "center", "top": 1230, "width": 1280 } },
    { "id": "state.settings", "type": "text", "text": "Settings", "layout": { "justify": "center", "align": "center", "top": 1260, "width": 1280 } },
    { "id": "state.fail-retry", "type": "text", "text": "Retry", "layout": { "justify": "center", "align": "center", "top": 1290, "width": 1280 } },
    { "id": "state.win-milestone", "type": "text", "text": "Order complete", "layout": { "justify": "center", "align": "center", "top": 1320, "width": 1280 } },
    { "id": "state.touch-controls", "type": "text", "text": "Touch cart mobile-control", "layout": { "justify": "center", "align": "center", "top": 1350, "width": 1280 } }
  ],
  "bindings": [
    { "node": "ingredients", "resource": "GameState.countdown" },
    { "node": "timer", "resource": "GameState.timerText" },
    { "node": "status", "resource": "GameState.status" }
  ]
}
