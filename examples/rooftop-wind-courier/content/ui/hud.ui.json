{
  "schema": "threenative.ui",
  "version": "0.1.0",
  "id": "hud",
  "nodes": [
    {
      "id": "parcels",
      "type": "text",
      "text": "Parcels 0/3",
      "style": { "color": "#f8fbff", "fontSize": 24, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 26, "width": 1280 }
    },
    {
      "id": "timer",
      "type": "text",
      "text": "Wind 62",
      "style": { "color": "#f8fbff", "fontSize": 22, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "top", "top": 62, "width": 1280 }
    },
    {
      "id": "status",
      "type": "text",
      "text": "Collect 3 parcels, then land on the green pad",
      "style": { "color": "#ffffff", "fontSize": 19, "fontWeight": "bold", "textAlign": "center" },
      "layout": { "justify": "center", "align": "bottom", "top": 676, "width": 1280 }
    }
    ,
    { "id": "state.loading", "type": "text", "text": "Loading rooftop route", "layout": { "justify": "center", "align": "center", "top": 1200, "width": 1280 } },
    { "id": "state.pause", "type": "text", "text": "Paused", "layout": { "justify": "center", "align": "center", "top": 1230, "width": 1280 } },
    { "id": "state.settings", "type": "text", "text": "Settings", "layout": { "justify": "center", "align": "center", "top": 1260, "width": 1280 } },
    { "id": "state.fail-retry", "type": "text", "text": "Route failed - press Space", "layout": { "justify": "center", "align": "center", "top": 1290, "width": 1280 } },
    { "id": "state.win-milestone", "type": "text", "text": "Delivery landed", "layout": { "justify": "center", "align": "center", "top": 1320, "width": 1280 } },
    { "id": "state.touch-controls", "type": "text", "text": "Touch glider mobile-control", "layout": { "justify": "center", "align": "center", "top": 1350, "width": 1280 } }
  ],
  "bindings": [
    { "node": "parcels", "resource": "GameState.parcelText" },
    { "node": "timer", "resource": "GameState.timerText" },
    { "node": "status", "resource": "GameState.status" }
  ]
}
