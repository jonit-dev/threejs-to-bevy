{
  "schema": "threenative.input",
  "version": "0.1.0",
  "id": "arena-input",
  "actions": [
    {
      "id": "move-left",
      "bindings": ["keyboard.KeyA", "keyboard.ArrowLeft"]
    },
    {
      "id": "move-right",
      "bindings": ["keyboard.KeyD", "keyboard.ArrowRight"]
    },
    {
      "id": "move-up",
      "bindings": ["keyboard.KeyW", "keyboard.ArrowUp"]
    },
    {
      "id": "move-down",
      "bindings": ["keyboard.KeyS", "keyboard.ArrowDown"]
    },
    {
      "id": "settings",
      "bindings": ["keyboard.KeyM"]
    },
    {
      "id": "retry",
      "bindings": ["keyboard.KeyR"]
    }
  ],
  "axes": [
    {
      "id": "MoveX",
      "negative": ["keyboard.KeyA", "keyboard.ArrowLeft"],
      "positive": ["keyboard.KeyD", "keyboard.ArrowRight"]
    },
    {
      "id": "MoveY",
      "negative": ["keyboard.KeyS", "keyboard.ArrowDown"],
      "positive": ["keyboard.KeyW", "keyboard.ArrowUp"]
    }
  ]
}
