{
  "schemaVersion": 1,
  "name": "progression",
  "target": "web",
  "viewport": { "width": 1280, "height": 720 },
  "subject": "player",
  "warmupFrames": 5,
  "steps": [
    {
      "label": "reach-rooftop-phase",
      "waitFrames": 130
    }
  ],
  "assert": {
    "resources": [
      { "id": "GameState", "path": "phase", "equals": "rooftop" },
      { "id": "GameState", "path": "batteries", "equals": 2 },
      { "id": "GameState", "path": "progress", "gte": 2 },
      { "id": "GameState", "path": "savedProgress", "textIncludes": "slot.main: rooftop:2" }
    ],
    "hud": [
      { "id": "phase", "textIncludes": "Rooftop" },
      { "id": "battery", "textIncludes": "Battery 2/2" },
      { "id": "saved", "textIncludes": "slot.main" }
    ],
    "diagnostics": {
      "runtimeReady": true,
      "noConsoleErrors": true,
      "noNetworkErrors": true,
      "noRuntimeDiagnostics": true
    }
  },
  "artifacts": {
    "screenshots": "before-after",
    "console": true,
    "network": true,
    "runtimeTrace": true,
    "effectLog": "focused"
  }
}
