{
  "schemaVersion": 1,
  "name": "chess-opening",
  "target": "web",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "subject": "piece.white.pawn.e2",
  "warmupFrames": 8,
  "steps": [
    {
      "label": "choose white side",
      "overlayMessage": {
        "overlayId": "chess-side-select",
        "type": "chess:choose-side",
        "payload": { "side": "white" }
      },
      "press": "KeyW",
      "holdFrames": 2,
      "release": true
    },
    {
      "label": "wait for side selection",
      "waitFrames": 4
    },
    {
      "label": "select e2 pawn",
      "press": "Enter",
      "holdFrames": 2,
      "release": true
    },
    {
      "label": "move cursor to e3",
      "press": "ArrowUp",
      "holdFrames": 2,
      "release": true
    },
    {
      "label": "commit e2-e3",
      "press": "Enter",
      "holdFrames": 2,
      "release": true
    },
    {
      "label": "observe eased move",
      "waitFrames": 4
    }
  ],
  "assert": {
    "movement": {
      "entity": "piece.white.pawn.e2",
      "axis": "z",
      "minDistance": 0.8
    },
    "resources": [
      {
        "id": "ChessGame",
        "path": "turnText",
        "equals": "YOUR TURN"
      }
    ],
    "hud": [
      {
        "id": "turn",
        "textIncludes": "YOUR TURN"
      },
      {
        "id": "overlay:chess-side-select",
        "path": "payload.playerSide",
        "equals": "white"
      }
    ],
    "diagnostics": {
      "runtimeReady": true,
      "noConsoleErrors": true,
      "noNetworkErrors": true,
      "noRuntimeDiagnostics": true
    },
    "visual": [
      {
        "entityVisible": {
          "entity": "board.surface",
          "minProjectedPixels": 100,
          "throughoutFrames": true
        }
      }
    ]
  },
  "artifacts": {
    "screenshots": "before-after",
    "console": true,
    "network": true,
    "runtimeTrace": true,
    "effectLog": "focused"
  }
}
