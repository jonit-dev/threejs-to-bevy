{
  "schemaVersion": 1,
  "name": "chess-overlay-native",
  "target": "desktop",
  "subject": "piece.white.pawn.e2",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "warmupFrames": 8,
  "steps": [
    {
      "label": "choose white through the native overlay bridge",
      "overlayMessage": {
        "overlayId": "chess-side-select",
        "type": "chess:choose-side",
        "payload": { "side": "white" }
      },
      "press": "KeyW",
      "holdFrames": 1,
      "release": true
    },
    {
      "label": "wait for the capture snapshot",
      "waitFrames": 8
    },
    {
      "label": "resize the composited overlay surface",
      "window": {
        "operation": "resize",
        "width": 1000,
        "height": 640
      },
      "waitFrames": 8,
      "screenshot": "resized"
    },
    {
      "label": "minimize the native window",
      "window": {
        "operation": "minimize"
      },
      "waitFrames": 4
    },
    {
      "label": "restore the native window and capture fresh pixels",
      "window": {
        "operation": "restore"
      },
      "waitFrames": 8,
      "screenshot": "restored"
    }
  ],
  "assert": {
    "hud": [
      {
        "id": "overlay:chess-side-select",
        "path": "payload.playerSide",
        "equals": "white"
      }
    ],
    "diagnostics": {
      "runtimeReady": true,
      "noConsoleErrors": true,
      "noNetworkErrors": true,
      "noRuntimeDiagnostics": true
    }
  },
  "artifacts": {
    "screenshots": true,
    "console": true,
    "network": true,
    "runtimeTrace": true,
    "effectLog": "focused"
  }
}
