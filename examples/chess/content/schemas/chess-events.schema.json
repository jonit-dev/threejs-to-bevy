{
  "schema": "threenative.schema",
  "version": "0.1.0",
  "id": "chess-events",
  "kind": "event",
  "schemas": [
    {
      "id": "chess:choose-side",
      "fields": {
        "side": { "kind": "string" }
      }
    },
    {
      "id": "chess:restart",
      "fields": {
        "source": { "kind": "string", "required": false, "default": "overlay" }
      }
    },
    {
      "id": "chess:captures",
      "fields": {
        "black": { "kind": "string" },
        "playerSide": { "kind": "string" },
        "white": { "kind": "string" }
      }
    }
  ]
}
