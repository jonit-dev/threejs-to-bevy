{
  "schema": "threenative.overlays",
  "version": "0.2.0",
  "overlays": [
    {
      "id": "chess-side-select",
      "entry": "overlay/chess-side-select/dist/index.html",
      "targetProfiles": ["web", "desktop"],
      "transparent": true,
      "zIndex": 30,
      "input": "modal",
      "messages": {
        "gameToOverlay": [
          {
            "name": "chess:captures",
            "schema": {
              "kind": "object",
              "fields": { "black": "string", "playerSide": "string", "white": "string" },
              "required": ["black", "playerSide", "white"]
            }
          }
        ],
        "overlayToGame": [
          {
            "name": "chess:choose-side",
            "schema": {
              "kind": "object",
              "fields": { "side": "string" },
              "required": ["side"]
            }
          },
          {
            "name": "chess:restart",
            "schema": {
              "kind": "object",
              "fields": {},
              "required": []
            }
          }
        ]
      }
    }
  ]
}
